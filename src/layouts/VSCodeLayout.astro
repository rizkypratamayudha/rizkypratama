---
interface Props {
  title?: string;
}

const { title = "Rizky Pratama Yudha | Portfolio" } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Rizky Pratama Yudha - Backend Developer Portfolio" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&family=Plus+Jakarta+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <script is:inline>
      (function() {
        try {
          var theme = localStorage.getItem('portfolio-theme');
          if (theme === 'light') {
            document.documentElement.classList.remove('dark');
            document.documentElement.classList.add('light');
          } else if (!theme && window.matchMedia('(prefers-color-scheme: light)').matches) {
            document.documentElement.classList.remove('dark');
            document.documentElement.classList.add('light');
          }
        } catch(e) {}
      })();
    </script>
  </head>
  <body class="bg-[#1e1e1e] dark:bg-[#1e1e1e] light:bg-[#ffffff] text-white dark:text-white light:text-[#333333] font-mono m-0 p-0 overflow-hidden transition-colors duration-200">
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --vscode-window: #1e1e1e;
    --vscode-sidebar: #252526;
    --vscode-activitybar: #333333;
    --vscode-tabbar: #252526;
    --vscode-editor: #1e1e1e;
    --vscode-panel: #1e1e1e;
    --vscode-statusbar: #007acc;
    --vscode-text: #d4d4d4;
    --vscode-text-muted: #858585;
    --vscode-accent: #007acc;
    --vscode-border: rgba(255, 255, 255, 0.08);
    --vscode-hover: rgba(255, 255, 255, 0.04);
  }

  .light {
    --vscode-window: #ffffff;
    --vscode-sidebar: #f3f3f3;
    --vscode-activitybar: #2c2c2c;
    --vscode-tabbar: #ececec;
    --vscode-editor: #ffffff;
    --vscode-panel: #f3f3f3;
    --vscode-statusbar: #007acc;
    --vscode-text: #333333;
    --vscode-text-muted: #616161;
    --vscode-accent: #007acc;
    --vscode-border: rgba(0, 0, 0, 0.1);
    --vscode-hover: rgba(0, 0, 0, 0.04);
  }

  * {
    box-sizing: border-box;
  }

  ::-webkit-scrollbar {
    width: 8px;
    height: 8px;
  }

  ::-webkit-scrollbar-track {
    background: var(--vscode-editor);
  }

  ::-webkit-scrollbar-thumb {
    background: #424242;
    border-radius: 4px;
  }

  ::-webkit-scrollbar-thumb:hover {
    background: #555;
  }

  .activity-btn {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #858585;
    transition: color 0.15s;
    cursor: pointer;
    border: none;
    background: transparent;
  }

  .activity-btn:hover {
    color: #ffffff;
  }

  .light .activity-btn:hover {
    color: #333333;
  }

  .activity-active {
    color: #ffffff !important;
    border-left: 2px solid #ffffff;
  }

  .light .activity-active {
    color: #333333 !important;
    border-left: 2px solid #333333;
  }

  .file-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 2px 12px;
    font-size: 13px;
    cursor: pointer;
    transition: background 0.1s;
    border: none;
    background: transparent;
    width: 100%;
    text-align: left;
    color: rgba(255, 255, 255, 0.5);
  }

  .light .file-item {
    color: rgba(0, 0, 0, 0.5);
  }

  .file-item:hover {
    background: var(--vscode-hover);
    color: rgba(255, 255, 255, 0.8);
  }

  .light .file-item:hover {
    color: rgba(0, 0, 0, 0.8);
  }

  .file-item.active {
    background: rgba(255, 255, 255, 0.1);
    color: #ffffff;
  }

  .light .file-item.active {
    background: rgba(0, 0, 0, 0.1);
    color: #333333;
  }

  .folder-item {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 2px 12px;
    font-size: 13px;
    cursor: pointer;
    user-select: none;
    color: rgba(255, 255, 255, 0.3);
  }

  .light .folder-item {
    color: rgba(0, 0, 0, 0.4);
  }

  .tab-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 0 16px;
    font-size: 13px;
    cursor: pointer;
    border-top: 2px solid transparent;
    transition: all 0.15s;
    height: 100%;
    white-space: nowrap;
  }

  .tab-item.active {
    background: var(--vscode-editor);
    color: #ffffff;
    border-top-color: #007acc;
  }

  .light .tab-item.active {
    color: #333333;
  }

  .tab-item:not(.active) {
    background: transparent;
    color: rgba(255, 255, 255, 0.4);
    border-top-color: transparent;
  }

  .light .tab-item:not(.active) {
    color: rgba(0, 0, 0, 0.4);
  }

  .tab-item:not(.active):hover {
    background: var(--vscode-hover);
    color: rgba(255, 255, 255, 0.7);
  }

  .light .tab-item:not(.active):hover {
    color: rgba(0, 0, 0, 0.7);
  }

  .editor-content {
    padding: 24px;
    line-height: 1.7;
  }

  .editor-content h1 {
    font-size: 2rem;
    font-weight: 600;
    margin-bottom: 8px;
    color: var(--vscode-text);
  }

  .editor-content h2 {
    font-size: 1.25rem;
    font-weight: 500;
    margin-top: 24px;
    margin-bottom: 8px;
    color: #569cd6;
  }

  .editor-content p {
    color: var(--vscode-text);
    margin-bottom: 12px;
  }

  .editor-content .comment {
    color: #6a9955;
  }

  .editor-content .key {
    color: #9cdcfe;
  }

  .light .editor-content .key {
    color: #0451a5;
  }

  .editor-content .string {
    color: #ce9178;
  }

  .light .editor-content .string {
    color: #a31515;
  }

  .editor-content .bracket {
    color: #ffd700;
  }

  .light .editor-content .bracket {
    color: #795e26;
  }

  /* Mobile responsive */
  @media (max-width: 768px) {
    .editor-content {
      padding: 16px;
    }

    .editor-content h1 {
      font-size: 1.5rem;
    }

    .editor-content h2 {
      font-size: 1.1rem;
    }
  }

  /* View Modes CSS */
  .panel-container {
    display: flex;
    flex-direction: row;
    height: 100%;
    width: 100%;
    min-height: 0;
  }

  [data-view-mode="code"] .code-panel {
    display: block !important;
    width: 100% !important;
  }
  [data-view-mode="code"] .preview-panel {
    display: none !important;
  }

  [data-view-mode="preview"] .code-panel {
    display: none !important;
  }
  [data-view-mode="preview"] .preview-panel {
    display: block !important;
    width: 100% !important;
  }

  [data-view-mode="split"] .code-panel {
    display: block !important;
    width: 25%;
    flex-shrink: 0;
  }
  [data-view-mode="split"] .preview-panel {
    display: block !important;
    width: 75%;
    flex-shrink: 0;
    border-left: none;
  }

  /* Resizer divider */
  .panel-resizer {
    display: none;
    width: 5px;
    flex-shrink: 0;
    cursor: col-resize;
    background: transparent;
    position: relative;
    z-index: 10;
    transition: background 0.15s;
  }
  .panel-resizer::after {
    content: '';
    position: absolute;
    top: 0; bottom: 0;
    left: 2px;
    width: 1px;
    background: var(--vscode-border);
    transition: background 0.15s, width 0.15s, left 0.15s;
  }
  .panel-resizer:hover::after,
  .panel-resizer.dragging::after {
    background: #007acc;
    width: 2px;
    left: 1.5px;
    box-shadow: 0 0 8px #007acc60;
  }
  [data-view-mode="split"] .panel-resizer {
    display: block;
  }

  /* Responsive view modes for mobile */
  @media (max-width: 1024px) {
    [data-view-mode="split"] .panel-container {
      flex-direction: column !important;
    }
    [data-view-mode="split"] .code-panel {
      width: 100% !important;
      height: 40% !important;
      flex-shrink: 0;
    }
    [data-view-mode="split"] .preview-panel {
      width: 100% !important;
      height: 60% !important;
      flex-shrink: 0;
      border-left: none !important;
      border-top: 1px solid var(--vscode-border) !important;
    }
    [data-view-mode="split"] .panel-resizer {
      display: none;
    }
  }

  /* ═══════════════════════════════════════════════════════════════════════════
     Visual Preview — Claymorphism (Dark & Light)
     ═══════════════════════════════════════════════════════════════════════════ */

  /* ── Preview Panel Base ──────────────────────────────────────────────── */
  .preview-panel {
    background: #0e1117;
    font-family: 'Plus Jakarta Sans', sans-serif !important;
    color: #e2e8f0;
    position: relative;
    overflow: hidden;
  }

  .preview-panel::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 500px 400px at 10% 15%, rgba(99, 102, 241, 0.07) 0%, transparent 70%),
      radial-gradient(ellipse 400px 400px at 90% 80%, rgba(59, 130, 246, 0.05) 0%, transparent 70%),
      radial-gradient(ellipse 350px 300px at 50% 95%, rgba(16, 185, 129, 0.04) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .preview-panel > * {
    position: relative;
    z-index: 1;
  }

  .light .preview-panel {
    background: #e8edf4;
    color: #1e293b;
  }

  .light .preview-panel::before {
    background:
      radial-gradient(ellipse 500px 400px at 10% 15%, rgba(99, 102, 241, 0.06) 0%, transparent 70%),
      radial-gradient(ellipse 400px 400px at 90% 80%, rgba(59, 130, 246, 0.04) 0%, transparent 70%),
      radial-gradient(ellipse 350px 300px at 50% 95%, rgba(16, 185, 129, 0.035) 0%, transparent 70%);
  }

  .preview-panel h1,
  .preview-panel h2,
  .preview-panel h3,
  .preview-panel h4 {
    font-family: 'Space Grotesk', sans-serif !important;
    letter-spacing: -0.025em;
  }

  /* ── Claymorphism Cards ──────────────────────────────────────────────── */
  .preview-card {
    background: linear-gradient(145deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0.01));
    border-radius: 20px;
    border: none;
    box-shadow:
      6px 6px 16px rgba(0, 0, 0, 0.35),
      -4px -4px 12px rgba(255, 255, 255, 0.03),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
    transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    overflow: hidden;
  }

  .preview-card::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(145deg, rgba(255, 255, 255, 0.04) 0%, transparent 40%);
    pointer-events: none;
  }

  .light .preview-card {
    background: linear-gradient(145deg, #ffffff, #f0f4f8);
    box-shadow:
      8px 8px 20px rgba(140, 160, 190, 0.45),
      -6px -6px 16px rgba(255, 255, 255, 0.95),
      inset 0 2px 0 rgba(255, 255, 255, 1),
      inset 0 -1px 0 rgba(140, 160, 190, 0.08);
  }

  .light .preview-card::after {
    background: linear-gradient(145deg, rgba(255, 255, 255, 0.7) 0%, transparent 50%);
  }

  .preview-card:hover {
    transform: translateY(-3px) scale(1.01);
    box-shadow:
      8px 8px 24px rgba(0, 0, 0, 0.4),
      -5px -5px 16px rgba(255, 255, 255, 0.04),
      inset 0 1px 0 rgba(255, 255, 255, 0.07);
  }

  .light .preview-card:hover {
    box-shadow:
      10px 10px 28px rgba(140, 160, 190, 0.5),
      -7px -7px 20px rgba(255, 255, 255, 1),
      inset 0 2px 0 rgba(255, 255, 255, 1),
      inset 0 -1px 0 rgba(140, 160, 190, 0.1);
  }

  /* Card color tints — Claymorphism */
  .preview-card.card-blue {
    background: linear-gradient(145deg, rgba(59, 130, 246, 0.08), rgba(59, 130, 246, 0.02));
    box-shadow:
      6px 6px 16px rgba(0, 0, 0, 0.3),
      -4px -4px 12px rgba(59, 130, 246, 0.04),
      inset 0 1px 0 rgba(59, 130, 246, 0.08);
  }
  .preview-card.card-blue:hover {
    box-shadow:
      8px 8px 24px rgba(0, 0, 0, 0.35),
      -5px -5px 16px rgba(59, 130, 246, 0.06),
      inset 0 1px 0 rgba(59, 130, 246, 0.12);
  }

  .preview-card.card-teal {
    background: linear-gradient(145deg, rgba(20, 184, 166, 0.08), rgba(20, 184, 166, 0.02));
    box-shadow:
      6px 6px 16px rgba(0, 0, 0, 0.3),
      -4px -4px 12px rgba(20, 184, 166, 0.04),
      inset 0 1px 0 rgba(20, 184, 166, 0.08);
  }
  .preview-card.card-teal:hover {
    box-shadow:
      8px 8px 24px rgba(0, 0, 0, 0.35),
      -5px -5px 16px rgba(20, 184, 166, 0.06),
      inset 0 1px 0 rgba(20, 184, 166, 0.12);
  }

  .preview-card.card-purple {
    background: linear-gradient(145deg, rgba(139, 92, 246, 0.08), rgba(139, 92, 246, 0.02));
    box-shadow:
      6px 6px 16px rgba(0, 0, 0, 0.3),
      -4px -4px 12px rgba(139, 92, 246, 0.04),
      inset 0 1px 0 rgba(139, 92, 246, 0.08);
  }
  .preview-card.card-purple:hover {
    box-shadow:
      8px 8px 24px rgba(0, 0, 0, 0.35),
      -5px -5px 16px rgba(139, 92, 246, 0.06),
      inset 0 1px 0 rgba(139, 92, 246, 0.12);
  }

  .preview-card.card-pink {
    background: linear-gradient(145deg, rgba(236, 72, 153, 0.08), rgba(236, 72, 153, 0.02));
    box-shadow:
      6px 6px 16px rgba(0, 0, 0, 0.3),
      -4px -4px 12px rgba(236, 72, 153, 0.04),
      inset 0 1px 0 rgba(236, 72, 153, 0.08);
  }
  .preview-card.card-pink:hover {
    box-shadow:
      8px 8px 24px rgba(0, 0, 0, 0.35),
      -5px -5px 16px rgba(236, 72, 153, 0.06),
      inset 0 1px 0 rgba(236, 72, 153, 0.12);
  }

  .light .preview-card.card-blue {
    background: linear-gradient(145deg, #e0ecff, #c8dbff);
    box-shadow:
      8px 8px 20px rgba(120, 150, 210, 0.4),
      -6px -6px 16px rgba(255, 255, 255, 0.95),
      inset 0 2px 0 rgba(255, 255, 255, 1),
      inset 0 -1px 0 rgba(80, 120, 200, 0.08);
  }
  .light .preview-card.card-teal {
    background: linear-gradient(145deg, #d5f5ec, #b8ede0);
    box-shadow:
      8px 8px 20px rgba(100, 170, 160, 0.35),
      -6px -6px 16px rgba(255, 255, 255, 0.95),
      inset 0 2px 0 rgba(255, 255, 255, 1),
      inset 0 -1px 0 rgba(20, 150, 130, 0.08);
  }
  .light .preview-card.card-purple {
    background: linear-gradient(145deg, #ede5ff, #ddd0fc);
    box-shadow:
      8px 8px 20px rgba(150, 130, 210, 0.35),
      -6px -6px 16px rgba(255, 255, 255, 0.95),
      inset 0 2px 0 rgba(255, 255, 255, 1),
      inset 0 -1px 0 rgba(130, 90, 230, 0.08);
  }
  .light .preview-card.card-pink {
    background: linear-gradient(145deg, #fce4f2, #f9d0e6);
    box-shadow:
      8px 8px 20px rgba(200, 140, 180, 0.35),
      -6px -6px 16px rgba(255, 255, 255, 0.95),
      inset 0 2px 0 rgba(255, 255, 255, 1),
      inset 0 -1px 0 rgba(220, 60, 130, 0.08);
  }

  /* ── Gradient Text ───────────────────────────────────────────────────── */
  .gradient-text {
    background: linear-gradient(135deg, #818cf8, #6366f1, #3b82f6, #10b981);
    background-size: 200% 200%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: gradient-shift 6s ease infinite;
  }

  .light .gradient-text {
    background: linear-gradient(135deg, #4f46e5, #4338ca, #2563eb, #059669);
    background-size: 200% 200%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* ── Gradient Borders (Clay) ─────────────────────────────────────────── */
  .gradient-border {
    position: relative;
    border-radius: 20px;
    background: linear-gradient(145deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0.01));
    border: none;
    box-shadow:
      6px 6px 16px rgba(0, 0, 0, 0.35),
      -4px -4px 12px rgba(255, 255, 255, 0.03),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  .gradient-border::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: 21px;
    padding: 1.5px;
    background: linear-gradient(145deg, #818cf8, #6366f1, #3b82f6, #10b981);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
    opacity: 0.15;
    transition: opacity 0.35s ease;
  }

  .gradient-border:hover::before {
    opacity: 0.45;
  }

  .light .gradient-border {
    background: linear-gradient(145deg, #ffffff, #f0f4f8);
    box-shadow:
      8px 8px 20px rgba(140, 160, 190, 0.45),
      -6px -6px 16px rgba(255, 255, 255, 0.95),
      inset 0 2px 0 rgba(255, 255, 255, 1),
      inset 0 -1px 0 rgba(140, 160, 190, 0.08);
  }

  .light .gradient-border::before {
    opacity: 0.2;
  }

  .light .gradient-border:hover::before {
    opacity: 0.5;
  }

  /* ── Pill Badges (Clay) ──────────────────────────────────────────────── */
  .pill-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 7px 16px;
    border-radius: 14px;
    font-size: 12px;
    font-weight: 500;
    font-family: 'JetBrains Mono', monospace;
    transition: all 0.3s ease;
  }

  .pill-badge-blue {
    background: linear-gradient(145deg, rgba(59, 130, 246, 0.12), rgba(59, 130, 246, 0.06));
    color: #60a5fa;
    box-shadow:
      3px 3px 8px rgba(0, 0, 0, 0.2),
      -2px -2px 6px rgba(59, 130, 246, 0.06),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  .pill-badge-teal {
    background: linear-gradient(145deg, rgba(20, 184, 166, 0.12), rgba(20, 184, 166, 0.06));
    color: #2dd4bf;
    box-shadow:
      3px 3px 8px rgba(0, 0, 0, 0.2),
      -2px -2px 6px rgba(20, 184, 166, 0.06),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  .pill-badge-purple {
    background: linear-gradient(145deg, rgba(139, 92, 246, 0.12), rgba(139, 92, 246, 0.06));
    color: #a78bfa;
    box-shadow:
      3px 3px 8px rgba(0, 0, 0, 0.2),
      -2px -2px 6px rgba(139, 92, 246, 0.06),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  .light .pill-badge-blue {
    background: linear-gradient(145deg, #d0e0ff, #b8d0ff);
    color: #1d4ed8;
    box-shadow:
      4px 4px 10px rgba(120, 150, 210, 0.35),
      -3px -3px 8px rgba(255, 255, 255, 0.95),
      inset 0 1px 0 rgba(255, 255, 255, 1);
  }

  .light .pill-badge-teal {
    background: linear-gradient(145deg, #b8f0e0, #9ae8d2);
    color: #0f766e;
    box-shadow:
      4px 4px 10px rgba(100, 170, 160, 0.3),
      -3px -3px 8px rgba(255, 255, 255, 0.95),
      inset 0 1px 0 rgba(255, 255, 255, 1);
  }

  .light .pill-badge-purple {
    background: linear-gradient(145deg, #e0d5ff, #d0c0ff);
    color: #6d28d9;
    box-shadow:
      4px 4px 10px rgba(150, 130, 210, 0.3),
      -3px -3px 8px rgba(255, 255, 255, 0.95),
      inset 0 1px 0 rgba(255, 255, 255, 1);
  }

  /* ── Buttons (Clay) ──────────────────────────────────────────────────── */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 11px 24px;
    border-radius: 14px;
    font-weight: 600;
    font-size: 13px;
    background: linear-gradient(145deg, #6366f1, #4f46e5);
    color: #fff;
    border: none;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow:
      4px 4px 12px rgba(79, 70, 229, 0.35),
      -3px -3px 10px rgba(129, 140, 248, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.15);
    position: relative;
    overflow: hidden;
  }

  .btn-primary::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(145deg, rgba(255,255,255,0.12) 0%, transparent 50%);
    pointer-events: none;
  }

  .btn-primary:hover {
    transform: translateY(-2px) scale(1.02);
    box-shadow:
      6px 6px 18px rgba(79, 70, 229, 0.4),
      -4px -4px 14px rgba(129, 140, 248, 0.12),
      inset 0 1px 0 rgba(255, 255, 255, 0.2);
  }

