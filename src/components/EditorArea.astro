                <span class="text-[11px] font-mono text-slate-500">Or reach me directly</span>
                <div class="flex items-center gap-2">
                  <a id="preview-contact-whatsapp" href={`https://wa.me/${(aboutData.whatsapp || '6282234052425').replace(/[^0-9]/g, '')}`} target="_blank" rel="noopener" class="p-3 rounded-2xl text-slate-300 hover:text-emerald-400 transition-all hover:scale-105" style="background: linear-gradient(145deg, rgba(255,255,255,0.05), rgba(255,255,255,0.02)); box-shadow: 3px 3px 8px rgba(0,0,0,0.2), -2px -2px 6px rgba(255,255,255,0.02), inset 0 1px 0 rgba(255,255,255,0.04);" title="Chat on WhatsApp">
