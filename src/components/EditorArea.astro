---
// Editor Area Component
import aboutData from '../data/about.json';
import skillsData from '../data/skills.json';
import projectsData from '../data/projects.json';

interface Props {
  activeSection?: string;
}

const { activeSection = 'index' } = Astro.props;
---

<main id="editor" class="flex-1 overflow-hidden" style="background: #1e1e1e;">
  <div class="h-full flex flex-col min-h-0">
    
    <!-- Index Section -->
    <section id="section-index" class={`flex-1 h-full min-h-0 ${activeSection !== 'index' ? 'hidden' : ''}`}>
      <div class="panel-container">
        
        <!-- Code Panel -->
        <div class="code-panel overflow-y-auto p-6 flex-1 min-w-0" style="background: #1e1e1e;">
          <div class="font-mono text-xs md:text-sm leading-relaxed" style="color: #d4d4d4;">
            <p class="comment">&lt;!-- index.html --&gt;</p>
            <p><span class="bracket">&lt;</span><span class="key">div</span> <span class="string">class</span>=<span class="string">"hero"</span><span class="bracket">&gt;</span></p>
            <p class="pl-4"><span class="bracket">&lt;</span><span class="key">h1</span><span class="bracket">&gt;</span><span id="code-index-name">{aboutData.name}</span><span class="bracket">&lt;/</span><span class="key">h1</span><span class="bracket">&gt;</span></p>
            <p class="pl-4"><span class="bracket">&lt;</span><span class="key">p</span> <span class="string">class</span>=<span class="string">"title"</span><span class="bracket">&gt;</span><span id="code-index-title">{aboutData.title}</span><span class="bracket">&lt;/</span><span class="key">p</span><span class="bracket">&gt;</span></p>
            <p class="pl-4"><span class="bracket">&lt;</span><span class="key">p</span> <span class="string">class</span>=<span class="string">"desc"</span><span class="bracket">&gt;</span><span id="code-index-desc">{aboutData.description}</span><span class="bracket">&lt;/</span><span class="key">p</span><span class="bracket">&gt;</span></p>
            
            <p class="pl-4 mt-3"><span class="bracket">&lt;</span><span class="key">div</span> <span class="string">class</span>=<span class="string">"quick-links"</span><span class="bracket">&gt;</span></p>
            <p class="pl-8"><span class="bracket">&lt;</span><span class="key">a</span> <span class="string">href</span>=<span class="string">"<span id="code-index-github">{aboutData.github}</span>"</span><span class="bracket">&gt;</span>GitHub<span class="bracket">&lt;/</span><span class="key">a</span><span class="bracket">&gt;</span></p>
            <p class="pl-8"><span class="bracket">&lt;</span><span class="key">a</span> <span class="string">href</span>=<span class="string">"mailto:<span id="code-index-email">{aboutData.email}</span>"</span><span class="bracket">&gt;</span>Email<span class="bracket">&lt;/</span><span class="key">a</span><span class="bracket">&gt;</span></p>
            <p class="pl-4"><span class="bracket">&lt;/</span><span class="key">div</span><span class="bracket">&gt;</span></p>
            <p><span class="bracket">&lt;/</span><span class="key">div</span><span class="bracket">&gt;</span></p>
            
            <div class="mt-6">
              <p class="comment">// Gunakan tombol toggle "View" di bagian atas</p>
              <p class="comment">// untuk beralih antara tampilan Kode dan Tampilan Visual.</p>
            </div>
          </div>
        </div>

        <!-- Panel Resizer -->
        <div class="panel-resizer" aria-hidden="true"></div>

        <!-- Preview Panel -->
        <div class="preview-panel overflow-y-auto p-6 md:p-12 min-w-0">
          <div class="w-full flex flex-col justify-center h-full min-h-[70vh]">
            <!-- Skeleton Loader -->
            <div id="preview-index-skeleton" class="space-y-6 animate-pulse">
              <div class="h-6 bg-slate-800/40 rounded-full w-28"></div>
              <div class="h-12 bg-gradient-to-r from-slate-800/60 to-slate-800/20 rounded-lg w-3/4"></div>
              <div class="h-8 bg-slate-800/40 rounded-lg w-1/2"></div>
              <div class="space-y-2.5">
                <div class="h-4 bg-slate-800/30 rounded w-full"></div>
                <div class="h-4 bg-slate-800/30 rounded w-5/6"></div>
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-8">
                <div class="h-14 bg-slate-800/20 rounded-lg"></div>
                <div class="h-14 bg-slate-800/20 rounded-lg"></div>
              </div>
            </div>

            <!-- Main Content (Hidden until loaded) -->
            <div id="preview-index-content" class="hidden space-y-6">
              <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-mono bg-blue-500/10 text-[#007acc] dark:text-[#38bdf8] border border-blue-500/20">
                <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
                Ready for Projects
              </div>
              <h1 class="preview-hero-title text-4xl font-extrabold tracking-tight" style="line-height: 1.1;">
                Hi, I'm <span id="preview-index-name-gradient" class="bg-gradient-to-r from-blue-500 to-teal-400 bg-clip-text text-transparent">{aboutData.name}</span>
              </h1>
              <p id="preview-index-title" class="preview-hero-subtitle text-xl font-semibold text-slate-400 dark:text-slate-300">
                {aboutData.title}
              </p>
              <p id="preview-index-desc" class="text-base text-slate-500 dark:text-slate-400 leading-relaxed w-full">
                {aboutData.description}
              </p>
              
              <div class="preview-info-grid grid grid-cols-2 gap-4 mt-8">
                <div class="p-3 rounded-lg bg-black/10 dark:bg-white/5 border border-slate-700/50 flex items-center gap-3">
                  <div class="p-2 rounded bg-blue-500/10 text-blue-500">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                  </div>
                  <div>
                    <p class="text-[10px] text-slate-500 uppercase tracking-wider font-mono">Location</p>
                    <p id="preview-index-location" class="text-xs font-medium">{aboutData.location}</p>
                  </div>
                </div>
                <div class="p-3 rounded-lg bg-black/10 dark:bg-white/5 border border-slate-700/50 flex items-center gap-3">
                  <div class="p-2 rounded bg-teal-500/10 text-teal-500">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 10v6M2 10v6M22 6c0-1.1-2-2-5-2H7C4 4 2 4.9 2 6M22 18c0 1.1-2 2-5 2H7c-3 0-5-.9-5-2M2 10c0 1.1 2 2 5 2h10c3 0 5-.9 5-2"></path></svg>
                  </div>
                  <div>
                    <p class="text-[10px] text-slate-500 uppercase tracking-wider font-mono">Education</p>
                    <p id="preview-index-education" class="text-xs font-medium truncate max-w-[180px]" title={aboutData.education}>{aboutData.education}</p>
                  </div>
                </div>
              </div>

              <div class="flex flex-wrap gap-4 pt-4">
                <a id="preview-index-cv" href={aboutData.cv} target="_blank" class="px-5 py-2.5 rounded font-medium text-sm flex items-center gap-2 bg-[#007acc] text-white hover:bg-[#0062a3] transition-colors shadow-lg shadow-blue-500/25">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"></path></svg>
                  Download CV
                </a>
                <button onclick="document.querySelector('[data-section=\'contact\']').click()" class="px-5 py-2.5 rounded font-medium text-sm flex items-center gap-2 border border-slate-600 hover:bg-slate-700/20 transition-colors">
                  Contact Me
                </button>
              </div>
            </div>
          </div>
        </div>
        
      </div>
    </section>

    <!-- About Section -->
    <section id="section-about" class={`flex-1 h-full min-h-0 ${activeSection !== 'about' ? 'hidden' : ''}`}>
      <div class="panel-container">
        
        <!-- Code Panel -->
        <div class="code-panel overflow-y-auto p-6 flex-1 min-w-0" style="background: #1e1e1e;">
          <div class="font-mono text-xs md:text-sm leading-relaxed" style="color: #d4d4d4;">
            <p class="comment">---</p>
            <p><span class="key">layout</span>: <span class="string">post</span></p>
            <p><span class="key">title</span>: <span class="string">"About Me"</span></p>
            <p><span class="key">author</span>: <span class="string">"{aboutData.name}"</span></p>
            <p class="comment">---</p>
            <br/>
            <p class="text-xl font-bold" style="color: #569cd6;"># About Me</p>
            <p class="mt-2" id="code-about-bio">{aboutData.bio}</p>
          </div>
        </div>

        <!-- Preview Panel -->
        <!-- Panel Resizer -->
        <div class="panel-resizer" aria-hidden="true"></div>

        <!-- Preview Panel -->
        <div class="preview-panel overflow-y-auto p-6 md:p-10 min-w-0">
          <div class="w-full space-y-8">

            <!-- Section Header -->
            <div class="flex items-center gap-4">
              <div>
                <h2 class="text-2xl font-bold mb-1 border-none pb-0 text-slate-200">About Me</h2>
                <div class="w-12 h-1 bg-[#007acc] rounded"></div>
              </div>
            </div>

            <!-- Skeleton Loader -->
            <div id="preview-about-skeleton" class="space-y-6 animate-pulse">
              <!-- Profile hero skeleton -->
              <div class="flex gap-5 p-5 rounded-xl border border-slate-800/60 bg-slate-800/10">
                <div class="w-20 h-20 rounded-full bg-slate-700/50 flex-shrink-0"></div>
                <div class="flex-1 space-y-3 pt-1">
                  <div class="h-5 bg-slate-700/50 rounded w-1/3"></div>
                  <div class="h-3 bg-slate-700/30 rounded w-1/4"></div>
                  <div class="flex gap-2 pt-1">
                    <div class="h-6 bg-slate-800/50 rounded-full w-28"></div>
                    <div class="h-6 bg-slate-800/50 rounded-full w-24"></div>
                  </div>
                </div>
              </div>
              <!-- Bio skeleton -->
              <div class="space-y-2 pl-4 border-l-2 border-slate-800/40">
                <div class="h-3 bg-slate-800/40 rounded w-full"></div>
                <div class="h-3 bg-slate-800/40 rounded w-5/6"></div>
                <div class="h-3 bg-slate-800/30 rounded w-full"></div>
                <div class="h-3 bg-slate-800/30 rounded w-4/5"></div>
              </div>
              <!-- Timeline skeleton -->
              <div class="space-y-4 pl-6 border-l-2 border-slate-800/30">
                <div class="h-4 bg-slate-800/40 rounded w-1/2"></div>
                <div class="h-3 bg-slate-800/30 rounded w-1/3"></div>
              </div>
            </div>

            <!-- Main Content (Hidden until loaded) -->
            <div id="preview-about-content" class="hidden space-y-8">

              <!-- Profile Hero Card -->
              <div class="preview-card p-5 rounded-xl flex flex-col sm:flex-row gap-5 items-start">
                <!-- Avatar -->
                <div class="w-20 h-20 rounded-full bg-gradient-to-tr from-blue-500 to-teal-400 p-[2.5px] shadow-lg shadow-blue-500/25 flex-shrink-0 overflow-hidden relative">
                  <div id="preview-about-avatar-fallback" class="w-full h-full rounded-full bg-slate-800 flex items-center justify-center text-xl font-bold font-mono text-white">
                    {aboutData.name.split(' ').map(w => w[0]).join('').slice(0, 3)}
                  </div>
                  <img
                    id="preview-about-avatar"
                    src={aboutData.avatar}
                    alt="Avatar"
                    class="absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-300 rounded-full"
                    onload="this.classList.remove('opacity-0')"
                    onerror="this.style.display='none'"
                  />
                </div>

                <!-- Profile Info -->
                <div class="flex-1 min-w-0 space-y-3">
                  <div>
                    <h3 id="preview-about-name" class="font-bold text-lg text-slate-100">{aboutData.name}</h3>
                    <p id="preview-about-title" class="text-sm text-[#007acc] font-mono mt-0.5">{aboutData.title}</p>
                  </div>
                  <!-- Contact pills -->
                  <div class="flex flex-wrap gap-2">
                    <span id="preview-about-email" class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-mono bg-slate-800/60 border border-slate-700/50 text-slate-300 hover:border-blue-500/40 transition-colors truncate max-w-full">
                      📧 {aboutData.email}
                    </span>
                    <span id="preview-about-location-detail" class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-mono bg-slate-800/60 border border-slate-700/50 text-slate-300">
                      📍 {aboutData.location}
                    </span>
                  </div>
                </div>
              </div>

              <!-- Bio Section -->
              <div class="space-y-3">
                <h4 class="text-xs font-mono uppercase tracking-wider text-slate-500">Biography</h4>
                <div id="preview-about-bio-container" class="space-y-3 pl-4 border-l-2 border-[#007acc]/40 text-sm leading-7 text-slate-300">
                  {aboutData.bio.split('\n\n').map((paragraph) => (
                    <p>{paragraph}</p>
                  ))}
                </div>
              </div>

              <!-- Education Timeline -->
              <div class="space-y-4">
                <h4 class="text-xs font-mono uppercase tracking-wider text-slate-500">Education Timeline</h4>
                <div id="preview-about-timeline" class="relative space-y-5 pl-6 border-l-2 border-slate-700/60 ml-2">
                  {aboutData.education_timeline.map((item) => (
                    <div class="relative">
                      <div class="absolute -left-[31px] top-2 w-3.5 h-3.5 rounded-full bg-[#007acc] border-[3px] border-slate-900 shadow-lg shadow-blue-500/30"></div>
                      <div class="preview-card rounded-lg p-4 space-y-1.5">
                        <span class="text-[10px] font-mono font-semibold px-2 py-0.5 rounded bg-blue-500/10 text-blue-400 border border-blue-500/20">{item.period}</span>
                        <h5 class="font-bold text-slate-200 mt-2 text-sm">{item.institution}</h5>
                        <p class="text-xs text-[#007acc] font-mono">{item.major}</p>
                        <p class="text-xs text-slate-400 leading-relaxed">{item.description}</p>
                      </div>
                    </div>
                  ))}
                </div>
              </div>

            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- Skills Section -->
    <section id="section-skills" class={`flex-1 h-full min-h-0 ${activeSection !== 'skills' ? 'hidden' : ''}`}>
      <div class="panel-container">
        
        <!-- Code Panel -->
        <div class="code-panel overflow-y-auto p-6 flex-1 min-w-0" style="background: #1e1e1e;">
          <pre id="code-skills-json" class="font-mono text-xs md:text-sm leading-relaxed" style="color: #d4d4d4;">
            <p class="comment">/**</p>
            <p class="comment"> * Skills & Technologies</p>
            <p class="comment"> * @source GitHub Issues (label: skill)</p>
            <p class="comment"> * @sync   Fetched at runtime — close an issue to publish</p>
            <p class="comment"> */</p>
            <br/>
            <p class="comment">// ⏳ Syncing skills from GitHub Issues...</p>
            <p class="bracket">&#123;</p>
            <div class="pl-4">
              <p><span class="key">"status"</span>: <span class="string">"loading"</span>,</p>
              <p><span class="key">"source"</span>: <span class="string">"github-issues"</span>,</p>
              <p><span class="key">"filter"</span>: <span class="string">"state=closed&label=skill"</span></p>
            </div>
            <p class="bracket">&#125;</p>
          </pre>
        </div>

        <!-- Panel Resizer -->
        <div class="panel-resizer" aria-hidden="true"></div>

        <!-- Preview Panel -->
        <div class="preview-panel overflow-y-auto p-6 md:p-10 min-w-0">
          <div class="w-full space-y-8">
            <div>
              <h2 class="text-2xl font-bold mb-1 border-none pb-0 text-slate-200">Skills Dashboard</h2>
              <div class="w-12 h-1 bg-[#007acc] rounded"></div>
            </div>

            <div id="preview-skills-grid" class="preview-grid-responsive grid grid-cols-2 gap-6">
              <div class="preview-card p-6 rounded-xl space-y-4 animate-pulse">
                <div class="h-4 bg-slate-800/60 rounded w-1/3"></div>
                <div class="flex flex-wrap gap-2 pt-1">
                  <div class="h-6 bg-slate-800/40 rounded w-16"></div>
                  <div class="h-6 bg-slate-800/40 rounded w-24"></div>
                  <div class="h-6 bg-slate-800/40 rounded w-12"></div>
                </div>
              </div>
              <div class="preview-card p-6 rounded-xl space-y-4 animate-pulse">
                <div class="h-4 bg-slate-800/60 rounded w-1/4"></div>
                <div class="flex flex-wrap gap-2 pt-1">
                  <div class="h-6 bg-slate-800/40 rounded w-20"></div>
                  <div class="h-6 bg-slate-800/40 rounded w-16"></div>
                  <div class="h-6 bg-slate-800/40 rounded w-20"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
        
      </div>
    </section>

    <!-- Projects Section -->
    <section id="section-projects" class={`flex-1 h-full min-h-0 ${activeSection !== 'projects' ? 'hidden' : ''}`}>
      <div class="panel-container">
        
        <!-- Code Panel -->
        <div class="code-panel overflow-y-auto p-6 flex-1 min-w-0" style="background: #1e1e1e;">
          <pre id="code-projects-json" class="font-mono text-xs md:text-sm leading-relaxed" style="color: #d4d4d4;">
            <p class="comment">/**</p>
            <p class="comment"> * Projects Portfolio</p>
            <p class="comment"> * @source GitHub Issues (label: project)</p>
            <p class="comment"> * @sync   Fetched at runtime — close an issue to publish</p>
            <p class="comment"> */</p>
            <br/>
            <p class="comment">// ⏳ Syncing projects from GitHub Issues...</p>
            <p class="bracket">[</p>
            <div class="pl-4">
              <p><span class="bracket">&#123;</span></p>
              <div class="pl-4">
                <p><span class="key">"status"</span>: <span class="string">"loading"</span>,</p>
                <p><span class="key">"source"</span>: <span class="string">"github-issues"</span>,</p>
                <p><span class="key">"filter"</span>: <span class="string">"state=closed&label=project"</span></p>
              </div>
              <p><span class="bracket">&#125;</span></p>
            </div>
            <p class="bracket">]</p>
          </pre>
        </div>

        <!-- Panel Resizer -->
        <div class="panel-resizer" aria-hidden="true"></div>

        <!-- Preview Panel -->
        <div class="preview-panel overflow-y-auto p-6 md:p-10 min-w-0">
          <div class="w-full space-y-8">
            <div>
              <h2 class="text-2xl font-bold mb-1 border-none pb-0 text-slate-200">Projects Portfolio</h2>
              <div class="w-12 h-1 bg-[#007acc] rounded"></div>
            </div>

            <div id="preview-projects-grid" class="preview-grid-responsive grid grid-cols-2 gap-6">
              <div class="preview-card gradient-border p-5 rounded-xl flex flex-col justify-between space-y-4 animate-pulse">
                <div class="h-32 rounded-lg bg-slate-800/40"></div>
                <div class="space-y-2">
                  <div class="h-4 bg-slate-800/60 rounded w-2/3"></div>
                  <div class="h-3 bg-slate-800/40 rounded w-full"></div>
                  <div class="h-3 bg-slate-800/40 rounded w-5/6"></div>
                </div>
              </div>
              <div class="preview-card gradient-border p-5 rounded-xl flex flex-col justify-between space-y-4 animate-pulse hidden md:flex">
                <div class="h-32 rounded-lg bg-slate-800/40"></div>
                <div class="space-y-2">
                  <div class="h-4 bg-slate-800/60 rounded w-1/2"></div>
                  <div class="h-3 bg-slate-800/40 rounded w-full"></div>
                  <div class="h-3 bg-slate-800/40 rounded w-4/5"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
        
      </div>
    </section>

    <!-- Contact Section -->
    <section id="section-contact" class={`flex-1 h-full min-h-0 ${activeSection !== 'contact' ? 'hidden' : ''}`}>
      <div class="panel-container">
        
        <!-- Code Panel -->
        <div class="code-panel overflow-y-auto p-6 flex-1 min-w-0" style="background: #1e1e1e;">
          <pre id="code-contact-json" class="font-mono text-xs md:text-sm leading-relaxed" style="color: #d4d4d4;">
            <p class="comment">// Contact Information</p>
            <p class="bracket">&#123;</p>
            <div class="pl-4">
              <p><span class="key">"name"</span>: <span class="string">"<span id="code-contact-name">{aboutData.name}</span>"</span>,</p>
              <p><span class="key">"title"</span>: <span class="string">"<span id="code-contact-title">{aboutData.title}</span>"</span>,</p>
              <p><span class="key">"email"</span>: <span class="string">"<span id="code-contact-email">{aboutData.email}</span>"</span>,</p>
              <p><span class="key">"github"</span>: <span class="string">"<span id="code-contact-github">{aboutData.github}</span>"</span>,</p>
              <p><span class="key">"location"</span>: <span class="string">"<span id="code-contact-location">{aboutData.location}</span>"</span>,</p>
              <p><span class="key">"availableForFreelance"</span>: <span style="color: #4ec9b0;">true</span></p>
            </div>
            <p class="bracket">&#125;</p>
          </pre>
        </div>

        <!-- Panel Resizer -->
        <div class="panel-resizer" aria-hidden="true"></div>

        <!-- Preview Panel -->
        <div class="preview-panel overflow-y-auto p-6 md:p-10 min-w-0">
          <div class="w-full space-y-8">
            <div>
              <h2 class="text-2xl font-bold mb-1 border-none pb-0 text-slate-200">Get In Touch</h2>
              <div class="w-12 h-1 bg-[#007acc] rounded"></div>
            </div>

            <div class="preview-card p-6 rounded-xl space-y-6">
              <div class="flex items-center gap-3">
                <span class="w-3 h-3 rounded-full bg-green-500 animate-pulse flex-shrink-0"></span>
                <span class="text-xs font-mono font-medium text-green-400">Available for freelance projects & full-time roles</span>
              </div>

              <!-- Simulated Form -->
              <div class="space-y-4">
                <div class="grid grid-cols-2 gap-4">
                  <div class="space-y-1.5">
                    <label class="text-[11px] font-mono text-slate-400">YOUR NAME</label>
                    <input type="text" placeholder="John Doe" class="w-full bg-slate-900/50 border border-slate-700/50 rounded px-3 py-2 text-xs focus:outline-none focus:border-[#007acc] text-slate-200" />
                  </div>
                  <div class="space-y-1.5">
                    <label class="text-[11px] font-mono text-slate-400">EMAIL ADDRESS</label>
                    <input type="email" placeholder="john@example.com" class="w-full bg-slate-900/50 border border-slate-700/50 rounded px-3 py-2 text-xs focus:outline-none focus:border-[#007acc] text-slate-200" />
                  </div>
                </div>
                <div class="space-y-1.5">
                  <label class="text-[11px] font-mono text-slate-400">MESSAGE</label>
                  <textarea rows="4" placeholder="Hello! I would love to talk about a project..." class="w-full bg-slate-900/50 border border-slate-700/50 rounded px-3 py-2 text-xs focus:outline-none focus:border-[#007acc] text-slate-200 resize-none"></textarea>
                </div>
                
                <button type="button" class="w-full py-2.5 rounded font-medium text-xs bg-[#007acc] text-white hover:bg-[#0062a3] transition-colors shadow-lg shadow-blue-500/10">
                  Send Message
                </button>
              </div>

              <div class="border-t border-slate-800/60 pt-4 flex justify-between items-center">
                <span class="text-[11px] font-mono text-slate-400">Or reach me directly at</span>
                <div class="flex items-center gap-3">
                  <a id="preview-contact-email" href={`mailto:${aboutData.email}`} class="p-2 rounded bg-slate-800 hover:bg-slate-700 transition-colors text-slate-300" title="Email Me">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                  </a>
                  <a id="preview-contact-github" href={aboutData.github} target="_blank" rel="noopener" class="p-2 rounded bg-slate-800 hover:bg-slate-700 transition-colors text-slate-300" title="My GitHub">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
        
      </div>
    </section>

  </div>
</main>

<script>
  // ── Responsive Preview Layout via ResizeObserver ──────────────────────────
  //
  // Tailwind breakpoints are viewport-based, so we need a ResizeObserver to
  // swap grid / text classes whenever the preview panel itself resizes.
  //
  function applyContainerStyles(panel: HTMLElement) {
    const w = panel.getBoundingClientRect().width;

    // ─── Grid targets ─────────────────────────────────────────────────────
    // Elements that should be 1-col when narrow, 2-col when wide
    panel.querySelectorAll<HTMLElement>('.preview-grid-responsive').forEach(el => {
      el.style.gridTemplateColumns = w < 500 ? '1fr' : '1fr 1fr';
    });

    // sm:grid-cols-2 for info cards (location/education)
    panel.querySelectorAll<HTMLElement>('.preview-info-grid').forEach(el => {
      el.style.gridTemplateColumns = w < 440 ? '1fr' : '1fr 1fr';
    });

    // ─── Typography ───────────────────────────────────────────────────────
    // h1 hero title: smaller when panel is cramped
    panel.querySelectorAll<HTMLElement>('.preview-hero-title').forEach(el => {
      el.classList.remove('text-3xl','text-4xl','text-5xl');
      if      (w < 380) el.classList.add('text-3xl');
      else if (w < 520) el.classList.add('text-4xl');
      else              el.classList.add('text-5xl');
    });

    // sub-title
    panel.querySelectorAll<HTMLElement>('.preview-hero-subtitle').forEach(el => {
      el.classList.remove('text-lg','text-xl','text-2xl');
      if (w < 420) el.classList.add('text-lg');
      else if (w < 560) el.classList.add('text-xl');
      else el.classList.add('text-2xl');
    });

    // ─── About: 3-col grid → 1-col when narrow ───────────────────────────
    panel.querySelectorAll<HTMLElement>('.preview-about-grid').forEach(el => {
      el.style.gridTemplateColumns = w < 540 ? '1fr' : '1fr 2fr';
    });

    // ─── Padding ─────────────────────────────────────────────────────────
    const narrow = w < 480;
    panel.style.padding = narrow ? '1rem' : '';
  }

  function initPreviewObservers() {
    const panels = document.querySelectorAll<HTMLElement>('.preview-panel');
    const ro = new ResizeObserver(entries => {
      entries.forEach(entry => {
        applyContainerStyles(entry.target as HTMLElement);
      });
    });
    panels.forEach(panel => {
      ro.observe(panel);
      applyContainerStyles(panel); // run once immediately
    });
  }

  // ── Panel Resizer Logic ────────────────────────────────────────────────────
  function initResizers() {
    const resizers = document.querySelectorAll<HTMLElement>('.panel-resizer');

    resizers.forEach((resizer) => {
      const container = resizer.closest<HTMLElement>('.panel-container');
      if (!container) return;
      const codePanel    = container.querySelector<HTMLElement>('.code-panel');
      const previewPanel = container.querySelector<HTMLElement>('.preview-panel');
      if (!codePanel || !previewPanel) return;

      let dragging  = false;
      let startX    = 0;
      let startCodeW = 0;

      resizer.addEventListener('mousedown', (e: MouseEvent) => {
        const editor = document.getElementById('editor');
        const viewMode = editor?.closest('[data-view-mode]')?.getAttribute('data-view-mode');
        if (viewMode !== 'split') return;

        dragging   = true;
        startX     = e.clientX;
        startCodeW = codePanel.getBoundingClientRect().width;
        resizer.classList.add('dragging');
        document.body.style.cursor     = 'col-resize';
        document.body.style.userSelect = 'none';
        e.preventDefault();
      });

      document.addEventListener('mousemove', (e: MouseEvent) => {
        if (!dragging) return;
        const totalW    = container.getBoundingClientRect().width;
        const delta     = e.clientX - startX;
        const newCodeW  = Math.min(Math.max(startCodeW + delta, totalW * 0.15), totalW * 0.75);
        const codePct   = (newCodeW / totalW) * 100;
        const prevPct   = 100 - codePct;

        codePanel.style.width    = `${codePct}%`;
        previewPanel.style.width = `${prevPct}%`;
        sessionStorage.setItem('panelSplitRatio', String(codePct.toFixed(1)));
      });

      document.addEventListener('mouseup', () => {
        if (!dragging) return;
        dragging = false;
        resizer.classList.remove('dragging');
        document.body.style.cursor     = '';
        document.body.style.userSelect = '';
      });
    });

    // Restore saved ratio
    const saved = sessionStorage.getItem('panelSplitRatio');
    if (saved) {
      const pct = parseFloat(saved);
      document.querySelectorAll<HTMLElement>('.code-panel').forEach(p   => p.style.width = `${pct}%`);
      document.querySelectorAll<HTMLElement>('.preview-panel').forEach(p => p.style.width = `${100 - pct}%`);
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    initResizers();
    initPreviewObservers();
  });
</script>

