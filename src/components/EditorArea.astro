---
// Editor Area Component
import aboutData from '../data/about.json';
import skillsData from '../data/skills.json';
import projectsData from '../data/projects.json';

interface Props {
  activeSection?: string;
}

const { activeSection = 'index' } = Astro.props;
---

<main id="editor" class="flex-1 overflow-hidden" style="background: var(--vscode-editor);">
  <div class="h-full flex flex-col min-h-0">
    <div class="panel-container">
      
      <!-- Code Panel (Left) -->
      <div class="code-panel overflow-y-auto p-6 flex-1 min-w-0" style="background: var(--vscode-editor);">
        
        <!-- Code Block: Index -->
        <div id="code-block-index" class="code-block font-mono text-xs md:text-sm leading-relaxed" style="color: var(--vscode-text);">
          <p class="comment">&lt;!-- index.html --&gt;</p>
          <p><span class="bracket">&lt;</span><span class="key">div</span> <span class="string">class</span>=<span class="string">"hero"</span><span class="bracket">&gt;</span></p>
          <p class="pl-4"><span class="bracket">&lt;</span><span class="key">h1</span><span class="bracket">&gt;</span><span id="code-index-name">{aboutData.name}</span><span class="bracket">&lt;/</span><span class="key">h1</span><span class="bracket">&gt;</span></p>
          <p class="pl-4"><span class="bracket">&lt;</span><span class="key">p</span> <span class="string">class</span>=<span class="string">"title"</span><span class="bracket">&gt;</span><span id="code-index-title">{aboutData.title}</span><span class="bracket">&lt;/</span><span class="key">p</span><span class="bracket">&gt;</span></p>
          <p class="pl-4"><span class="bracket">&lt;</span><span class="key">p</span> <span class="string">class</span>=<span class="string">"desc"</span><span class="bracket">&gt;</span><span id="code-index-desc">{aboutData.description}</span><span class="bracket">&lt;/</span><span class="key">p</span><span class="bracket">&gt;</span></p>
          
          <p class="pl-4 mt-3"><span class="bracket">&lt;</span><span class="key">div</span> <span class="string">class</span>=<span class="string">"quick-links"</span><span class="bracket">&gt;</span></p>
          <p class="pl-8"><span class="bracket">&lt;</span><span class="key">a</span> <span class="string">href</span>=<span class="string">"<span id="code-index-github">{aboutData.github}</span>"</span><span class="bracket">&gt;</span>GitHub<span class="bracket">&lt;/</span><span class="key">a</span><span class="bracket">&gt;</span></p>
          <p class="pl-8"><span class="bracket">&lt;</span><span class="key">a</span> <span class="string">href</span>=<span class="string">"mailto:<span id="code-index-email">{aboutData.email}</span>"</span><span class="bracket">&gt;</span>Email<span class="bracket">&lt;/</span><span class="key">a</span><span class="bracket">&gt;</span></p>
          <p class="pl-4"><span class="bracket">&lt;/</span><span class="key">div</span><span class="bracket">&gt;</span></p>
          <p><span class="bracket">&lt;/</span><span class="key">div</span><span class="bracket">&gt;</span></p>
          
          <div class="mt-6">
            <p class="comment">// Scroll panel preview di kanan untuk melihat bagian lainnya,</p>
            <p class="comment">// atau klik tab/file di sidebar untuk berpindah langsung.</p>
          </div>
        </div>

        <!-- Code Block: About -->
        <div id="code-block-about" class="code-block hidden font-mono text-xs md:text-sm leading-relaxed" style="color: var(--vscode-text);">
          <p class="comment">---</p>
          <p><span class="key">layout</span>: <span class="string">post</span></p>
          <p><span class="key">title</span>: <span class="string">"About Me"</span></p>
          <p><span class="key">author</span>: <span class="string">"{aboutData.name}"</span></p>
          <p class="comment">---</p>
          <br/>
          <p class="text-xl font-bold syntax-heading"># About Me</p>
          <p class="mt-2" id="code-about-bio">{aboutData.bio}</p>
        </div>

        <!-- Code Block: Skills -->
        <div id="code-block-skills" class="code-block hidden font-mono text-xs md:text-sm leading-relaxed" style="color: var(--vscode-text);">
          <pre id="code-skills-json" class="font-mono text-xs md:text-sm leading-relaxed" style="color: var(--vscode-text);">
            <p class="comment">/**</p>
            <p class="comment"> * Skills & Technologies</p>
            <p class="comment"> * @source GitHub Issues (label: skill)</p>
            <p class="comment"> * @sync   Fetched at runtime — close an issue to publish</p>
            <p class="comment"> */</p>
            <br/>
            <p class="comment">// ⏳ Syncing skills from GitHub Issues...</p>
            <p class="bracket">&#123;</p>
            <div class="pl-4">
              <p><span class="key">"status"</span>: <span class="string">"loading"</span>,</p>
              <p><span class="key">"source"</span>: <span class="string">"github-issues"</span>,</p>
              <p><span class="key">"filter"</span>: <span class="string">"state=closed&label=skill"</span></p>
            </div>
            <p class="bracket">&#125;</p>
          </pre>
        </div>

        <!-- Code Block: Projects -->
        <div id="code-block-projects" class="code-block hidden font-mono text-xs md:text-sm leading-relaxed" style="color: var(--vscode-text);">
          <pre id="code-projects-json" class="font-mono text-xs md:text-sm leading-relaxed" style="color: var(--vscode-text);">
            <p class="comment">/**</p>
            <p class="comment"> * Projects Portfolio</p>
            <p class="comment"> * @source GitHub Issues (label: project)</p>
            <p class="comment"> * @sync   Fetched at runtime — close an issue to publish</p>
            <p class="comment"> */</p>
            <br/>
            <p class="comment">// ⏳ Syncing projects from GitHub Issues...</p>
            <p class="bracket">[</p>
            <div class="pl-4">
              <p><span class="bracket">&#123;</span></p>
              <div class="pl-4">
                <p><span class="key">"status"</span>: <span class="string">"loading"</span>,</p>
                <p><span class="key">"source"</span>: <span class="string">"github-issues"</span>,</p>
                <p><span class="key">"filter"</span>: <span class="string">"state=closed&label=project"</span></p>
              </div>
              <p><span class="bracket">&#125;</span></p>
            </div>
            <p class="bracket">]</p>
          </pre>
        </div>

        <!-- Code Block: Contact -->
        <div id="code-block-contact" class="code-block hidden font-mono text-xs md:text-sm leading-relaxed" style="color: var(--vscode-text);">
          <pre id="code-contact-json" class="font-mono text-xs md:text-sm leading-relaxed" style="color: var(--vscode-text);">
            <p class="comment">// Contact Information</p>
            <p class="bracket">&#123;</p>
            <div class="pl-4">
              <p><span class="key">"name"</span>: <span class="string">"<span id="code-contact-name">{aboutData.name}</span>"</span>,</p>
              <p><span class="key">"title"</span>: <span class="string">"<span id="code-contact-title">{aboutData.title}</span>"</span>,</p>
              <p><span class="key">"email"</span>: <span class="string">"<span id="code-contact-email">{aboutData.email}</span>"</span>,</p>
              <p><span class="key">"whatsapp"</span>: <span class="string">"<span id="code-contact-whatsapp">{aboutData.whatsapp || "6282234052425"}</span>"</span>,</p>
              <p><span class="key">"github"</span>: <span class="string">"<span id="code-contact-github">{aboutData.github}</span>"</span>,</p>
              <p><span class="key">"location"</span>: <span class="string">"<span id="code-contact-location">{aboutData.location}</span>"</span>,</p>
              <p><span class="key">"availableForFreelance"</span>: <span class="syntax-boolean">true</span></p>
            </div>
            <p class="bracket">&#125;</p>
          </pre>
        </div>

      </div>

      <!-- Panel Resizer -->
      <div class="panel-resizer" aria-hidden="true"></div>

      <!-- Preview Panel (Continuous Scroll Container) -->
      <div id="main-preview-panel" class="preview-panel overflow-y-auto p-6 md:p-12 min-w-0 scroll-smooth">
        <div class="w-full space-y-16">
          
          <!-- Section 1: Index / Hero -->
          <section id="section-index" data-section-name="index" class="min-h-[70vh] flex flex-col justify-center scroll-mt-6">
            <!-- Skeleton Loader -->
            <div id="preview-index-skeleton" class="space-y-6 animate-pulse">
              <div class="h-6 bg-slate-800/40 rounded-full w-28"></div>
              <div class="h-12 bg-gradient-to-r from-slate-800/60 to-slate-800/20 rounded-lg w-3/4"></div>
              <div class="h-8 bg-slate-800/40 rounded-lg w-1/2"></div>
              <div class="space-y-2.5">
                <div class="h-4 bg-slate-800/30 rounded w-full"></div>
                <div class="h-4 bg-slate-800/30 rounded w-5/6"></div>
              </div>
              <div class="bento-grid mt-8">
                <div class="h-20 bg-slate-800/20 rounded-xl"></div>
                <div class="h-20 bg-slate-800/20 rounded-xl"></div>
              </div>
            </div>

            <!-- Main Content (Hidden until loaded) -->
            <div id="preview-index-content" class="hidden space-y-7">
              <!-- Status pill -->
              <div class="animate-fade-in-up">
                <span class="pill-badge pill-badge-teal">
                  <span class="w-2 h-2 rounded-full bg-teal-400 animate-pulse"></span>
                  Available for Projects
                </span>
              </div>

              <!-- Hero title -->
              <div class="space-y-3 animate-fade-in-up" style="animation-delay: 0.1s;">
                <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight font-display" style="line-height: 1.05;">
                  Hi, I'm <span id="preview-index-name-gradient" class="gradient-text">{aboutData.name}</span>
                </h1>
                <p id="preview-index-title" class="preview-hero-subtitle text-lg md:text-xl font-medium text-slate-400">
                  {aboutData.title}
                </p>
              </div>

              <!-- Description -->
              <p id="preview-index-desc" class="text-sm md:text-base text-slate-400/80 leading-relaxed max-w-xl animate-fade-in-up" style="animation-delay: 0.2s;">
                {aboutData.description}
              </p>

              <!-- Bento Info Grid -->
              <div class="bento-grid mt-8 animate-fade-in-up" style="animation-delay: 0.3s;">
                <div class="preview-card card-blue rounded-xl p-4 flex items-center gap-3">
                  <div class="p-2.5 rounded-lg bg-blue-500/10 text-blue-400">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                  </div>
                  <div>
                    <p class="text-[10px] text-slate-500 uppercase tracking-wider font-mono">Location</p>
                    <p id="preview-index-location" class="text-sm font-semibold text-slate-200">{aboutData.location}</p>
                  </div>
                </div>
                <div class="preview-card card-teal rounded-xl p-4 flex items-center gap-3">
                  <div class="p-2.5 rounded-lg bg-teal-500/10 text-teal-400">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 10v6M2 10v6M22 6c0-1.1-2-2-5-2H7C4 4 2 4.9 2 6M22 18c0 1.1-2 2-5 2H7c-3 0-5-.9-5-2M2 10c0 1.1 2 2 5 2h10c3 0 5-.9 5-2"></path></svg>
                  </div>
                  <div>
                    <p class="text-[10px] text-slate-500 uppercase tracking-wider font-mono">Education</p>
                    <p id="preview-index-education" class="text-sm font-semibold text-slate-200 truncate max-w-[180px]" title={aboutData.education}>{aboutData.education}</p>
                  </div>
                </div>
              </div>

              <!-- Action Buttons -->
              <div class="flex flex-wrap gap-3 pt-2 animate-fade-in-up" style="animation-delay: 0.4s;">
                <a id="preview-index-cv" href={aboutData.cv} target="_blank" class="btn-primary">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"></path></svg>
                  Download CV
                </a>
                <button onclick="document.querySelector('[data-section=\'contact\']').click()" class="btn-ghost">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                  Contact Me
                </button>
              </div>
            </div>
          </section>

          <hr class="border-slate-800/80 my-10" />

          <!-- Section 2: About Me -->
          <section id="section-about" data-section-name="about" class="space-y-8 scroll-mt-6">
            <!-- Section Header -->
            <div class="flex items-center gap-4">
              <div>
                <h2 class="text-2xl font-bold mb-1 border-none pb-0 text-slate-200 font-display">About Me</h2>
                <div class="w-10 h-1 bg-gradient-to-r from-indigo-500 to-teal-400 rounded-full"></div>
              </div>
            </div>

            <!-- Skeleton Loader -->
            <div id="preview-about-skeleton" class="space-y-6 animate-pulse">
              <div class="flex gap-5 p-5 rounded-xl border border-slate-800/60 bg-slate-800/10">
                <div class="w-20 h-20 rounded-full bg-slate-700/50 flex-shrink-0"></div>
                <div class="flex-1 space-y-3 pt-1">
                  <div class="h-5 bg-slate-700/50 rounded w-1/3"></div>
                  <div class="h-3 bg-slate-700/30 rounded w-1/4"></div>
                  <div class="flex gap-2 pt-1">
                    <div class="h-6 bg-slate-800/50 rounded-full w-28"></div>
                    <div class="h-6 bg-slate-800/50 rounded-full w-24"></div>
                  </div>
                </div>
              </div>
              <div class="space-y-2 pl-4 border-l-2 border-slate-800/40">
                <div class="h-3 bg-slate-800/40 rounded w-full"></div>
                <div class="h-3 bg-slate-800/40 rounded w-5/6"></div>
              </div>
            </div>

            <!-- Main Content (Hidden until loaded) -->
            <div id="preview-about-content" class="hidden space-y-8">
              <!-- Profile Hero Card -->
              <div class="preview-card card-blue rounded-2xl p-5 flex flex-col sm:flex-row gap-5 items-start animate-fade-in-up">
                <!-- Avatar -->
                <div class="w-20 h-20 rounded-full bg-gradient-to-tr from-indigo-500 via-blue-500 to-teal-400 p-[2.5px] shadow-lg shadow-indigo-500/25 flex-shrink-0 overflow-hidden relative">
                  <div id="preview-about-avatar-fallback" class="w-full h-full rounded-full bg-slate-800 flex items-center justify-center text-xl font-bold font-mono text-white">
                    {aboutData.name.split(' ').map(w => w[0]).join('').slice(0, 3)}
                  </div>
                  <img
                    id="preview-about-avatar"
                    src={aboutData.avatar}
                    alt="Avatar"
                    class="absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-300 rounded-full"
                    onload="this.classList.remove('opacity-0')"
                    onerror="this.style.display='none'"
                  />
                </div>

                <!-- Profile Info -->
                <div class="flex-1 min-w-0 space-y-3">
                  <div>
                    <h3 id="preview-about-name" class="font-bold text-lg text-slate-100 font-display">{aboutData.name}</h3>
                    <p id="preview-about-title" class="text-sm text-indigo-400 font-mono mt-0.5">{aboutData.title}</p>
                  </div>
                  <div class="flex flex-wrap gap-2">
                    <span id="preview-about-email" class="pill-badge pill-badge-blue truncate max-w-full">
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                      {aboutData.email}
                    </span>
                    <span id="preview-about-location-detail" class="pill-badge pill-badge-teal">
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                      {aboutData.location}
                    </span>
                  </div>
                </div>
              </div>

              <!-- Bio Section -->
              <div class="space-y-3 animate-fade-in-up" style="animation-delay: 0.1s;">
                <h4 class="text-xs font-mono uppercase tracking-wider text-slate-500 flex items-center gap-2">
                  <span class="w-4 h-[1px] bg-slate-700"></span>
                  Biography
                </h4>
                <div id="preview-about-bio-container" class="space-y-3 pl-4 border-l-2 border-indigo-500/30 text-sm leading-7 text-slate-300/90">
                  {aboutData.bio.split('\n\n').map((paragraph) => (
                    <p>{paragraph}</p>
                  ))}
                </div>
              </div>

              <!-- Work Experience Timeline -->
              <div class="space-y-4 animate-fade-in-up" style="animation-delay: 0.15s;">
                <h4 class="text-xs font-mono uppercase tracking-wider text-slate-500 flex items-center gap-2">
                  <span class="w-4 h-[1px] bg-slate-700"></span>
                  Work Experience
                </h4>
                <div id="preview-about-experience" class="relative space-y-5 pl-6 border-l-2 border-teal-500/40 ml-2">
                  {aboutData.work_experience && aboutData.work_experience.length > 0 ? (
                    aboutData.work_experience.map((item, i) => (
                      <div class={`relative animate-fade-in-up stagger-${i + 1}`}>
                        <div class="absolute -left-[31px] top-3 w-3 h-3 rounded-full bg-gradient-to-br from-teal-400 to-indigo-500 border-[3px] border-[#080b14] shadow-lg shadow-teal-500/30"></div>
                        <div class={`preview-card rounded-xl p-4 space-y-2 ${i % 2 === 0 ? 'card-teal' : 'card-blue'}`}>
                          <div class="flex flex-wrap items-center justify-between gap-2">
                            <span class="pill-badge pill-badge-teal text-[10px] px-2 py-0.5">{item.period}</span>
                            {item.location && <span class="text-[10px] font-mono text-slate-500">{item.location}</span>}
                          </div>
                          <h5 class="font-bold text-slate-200 mt-1 text-sm font-display">{item.role}</h5>
                          <p class="text-xs text-teal-400 font-mono font-semibold">{item.company}</p>
                          <p class="text-xs text-slate-400/80 leading-relaxed whitespace-pre-line">{item.description}</p>
                          {item.technologies && item.technologies.length > 0 && (
                            <div class="flex flex-wrap gap-1.5 pt-1">
                              {item.technologies.map((t) => (
                                <span class="skill-tag tag-teal text-[10px]">{t}</span>
                              ))}
                            </div>
                          )}
                        </div>
                      </div>
                    ))
                  ) : (
                    <p class="text-xs font-mono text-slate-500 italic pl-1">Belum ada pengalaman kerja terdaftar. Tambahkan via GitHub Issues!</p>
                  )}
                </div>
              </div>

              <hr class="section-divider" />

              <!-- Education Timeline -->
              <div class="space-y-4 animate-fade-in-up" style="animation-delay: 0.2s;">
                <h4 class="text-xs font-mono uppercase tracking-wider text-slate-500 flex items-center gap-2">
                  <span class="w-4 h-[1px] bg-slate-700"></span>
                  Education Timeline
                </h4>
                <div id="preview-about-timeline" class="relative space-y-5 pl-6 border-l-2 border-slate-700/40 ml-2">
                  {aboutData.education_timeline.map((item, i) => (
                    <div class={`relative animate-fade-in-up stagger-${i + 1}`}>
                      <div class="absolute -left-[31px] top-3 w-3 h-3 rounded-full bg-gradient-to-br from-indigo-500 to-blue-500 border-[3px] border-[#080b14] shadow-lg shadow-indigo-500/30"></div>
                      <div class={`preview-card rounded-xl p-4 space-y-2 ${i % 2 === 0 ? 'card-blue' : 'card-purple'}`}>
                        <span class="pill-badge pill-badge-purple text-[10px] px-2 py-0.5">{item.period}</span>
                        <h5 class="font-bold text-slate-200 mt-1 text-sm font-display">{item.institution}</h5>
                        <p class="text-xs text-indigo-400 font-mono">{item.major}</p>
                        <p class="text-xs text-slate-400/80 leading-relaxed">{item.description}</p>
                      </div>
                    </div>
                  ))}
                </div>
              </div>

            </div>
          </section>

          <hr class="border-slate-800/80 my-10" />

          <!-- Section 3: Skills Dashboard -->
          <section id="section-skills" data-section-name="skills" class="space-y-8 scroll-mt-6">
            <div>
              <h2 class="text-2xl font-bold mb-1 border-none pb-0 text-slate-200 font-display">Skills Dashboard</h2>
              <div class="w-10 h-1 bg-gradient-to-r from-indigo-500 to-teal-400 rounded-full"></div>
            </div>

            <div id="preview-skills-grid" class="bento-grid">
              <div class="preview-card card-blue rounded-xl p-5 space-y-4 animate-pulse">
                <div class="h-4 bg-slate-800/60 rounded w-1/3"></div>
                <div class="flex flex-wrap gap-2 pt-1">
                  <div class="h-7 bg-slate-800/40 rounded-lg w-16"></div>
                  <div class="h-7 bg-slate-800/40 rounded-lg w-24"></div>
                  <div class="h-7 bg-slate-800/40 rounded-lg w-12"></div>
                </div>
              </div>
              <div class="preview-card card-teal rounded-xl p-5 space-y-4 animate-pulse">
                <div class="h-4 bg-slate-800/60 rounded w-1/4"></div>
                <div class="flex flex-wrap gap-2 pt-1">
                  <div class="h-7 bg-slate-800/40 rounded-lg w-20"></div>
                  <div class="h-7 bg-slate-800/40 rounded-lg w-16"></div>
                  <div class="h-7 bg-slate-800/40 rounded-lg w-20"></div>
                </div>
              </div>
              <div class="preview-card card-purple rounded-xl p-5 space-y-4 animate-pulse">
                <div class="h-4 bg-slate-800/60 rounded w-1/3"></div>
                <div class="flex flex-wrap gap-2 pt-1">
                  <div class="h-7 bg-slate-800/40 rounded-lg w-14"></div>
                  <div class="h-7 bg-slate-800/40 rounded-lg w-20"></div>
                </div>
              </div>
              <div class="preview-card card-pink rounded-xl p-5 space-y-4 animate-pulse">
                <div class="h-4 bg-slate-800/60 rounded w-1/4"></div>
                <div class="flex flex-wrap gap-2 pt-1">
                  <div class="h-7 bg-slate-800/40 rounded-lg w-16"></div>
                  <div class="h-7 bg-slate-800/40 rounded-lg w-24"></div>
                </div>
              </div>
            </div>
          </section>

          <hr class="border-slate-800/80 my-10" />

          <!-- Section 4: Projects Portfolio -->
          <section id="section-projects" data-section-name="projects" class="space-y-8 scroll-mt-6">
            <div>
              <h2 class="text-2xl font-bold mb-1 border-none pb-0 text-slate-200 font-display">Projects Portfolio</h2>
              <div class="w-10 h-1 bg-gradient-to-r from-indigo-500 to-teal-400 rounded-full"></div>
            </div>

            <div id="preview-projects-grid" class="bento-grid">
              <div class="preview-card gradient-border rounded-xl p-5 flex flex-col justify-between space-y-4 animate-pulse">
