---
// Editor Area Component
import aboutData from '../data/about.json';
import skillsData from '../data/skills.json';
import projectsData from '../data/projects.json';

interface Props {
  activeSection?: string;
}

const { activeSection = 'index' } = Astro.props;
---

<main id="editor" class="flex-1 overflow-hidden" style="background: #1e1e1e;">
  <div class="h-full flex flex-col min-h-0">
    
    <!-- Index Section -->
    <section id="section-index" class={`flex-1 h-full min-h-0 ${activeSection !== 'index' ? 'hidden' : ''}`}>
      <div class="panel-container">
        
        <!-- Code Panel -->
        <div class="code-panel overflow-y-auto p-6 flex-1 min-w-0" style="background: #1e1e1e;">
          <div class="font-mono text-xs md:text-sm leading-relaxed" style="color: #d4d4d4;">
            <p class="comment">&lt;!-- index.html --&gt;</p>
            <p><span class="bracket">&lt;</span><span class="key">div</span> <span class="string">class</span>=<span class="string">"hero"</span><span class="bracket">&gt;</span></p>
            <p class="pl-4"><span class="bracket">&lt;</span><span class="key">h1</span><span class="bracket">&gt;</span><span id="code-index-name">{aboutData.name}</span><span class="bracket">&lt;/</span><span class="key">h1</span><span class="bracket">&gt;</span></p>
            <p class="pl-4"><span class="bracket">&lt;</span><span class="key">p</span> <span class="string">class</span>=<span class="string">"title"</span><span class="bracket">&gt;</span><span id="code-index-title">{aboutData.title}</span><span class="bracket">&lt;/</span><span class="key">p</span><span class="bracket">&gt;</span></p>
            <p class="pl-4"><span class="bracket">&lt;</span><span class="key">p</span> <span class="string">class</span>=<span class="string">"desc"</span><span class="bracket">&gt;</span><span id="code-index-desc">{aboutData.description}</span><span class="bracket">&lt;/</span><span class="key">p</span><span class="bracket">&gt;</span></p>
            
            <p class="pl-4 mt-3"><span class="bracket">&lt;</span><span class="key">div</span> <span class="string">class</span>=<span class="string">"quick-links"</span><span class="bracket">&gt;</span></p>
            <p class="pl-8"><span class="bracket">&lt;</span><span class="key">a</span> <span class="string">href</span>=<span class="string">"<span id="code-index-github">{aboutData.github}</span>"</span><span class="bracket">&gt;</span>GitHub<span class="bracket">&lt;/</span><span class="key">a</span><span class="bracket">&gt;</span></p>
            <p class="pl-8"><span class="bracket">&lt;</span><span class="key">a</span> <span class="string">href</span>=<span class="string">"mailto:<span id="code-index-email">{aboutData.email}</span>"</span><span class="bracket">&gt;</span>Email<span class="bracket">&lt;/</span><span class="key">a</span><span class="bracket">&gt;</span></p>
            <p class="pl-4"><span class="bracket">&lt;/</span><span class="key">div</span><span class="bracket">&gt;</span></p>
            <p><span class="bracket">&lt;/</span><span class="key">div</span><span class="bracket">&gt;</span></p>
            
            <div class="mt-6">
              <p class="comment">// Gunakan tombol toggle "View" di bagian atas</p>
              <p class="comment">// untuk beralih antara tampilan Kode dan Tampilan Visual.</p>
            </div>
          </div>
        </div>

        <!-- Preview Panel -->
        <div class="preview-panel overflow-y-auto p-6 md:p-12 flex-1 min-w-0">
          <div class="max-w-2xl mx-auto flex flex-col justify-center h-full min-h-[70vh]">
            <div class="space-y-6">
              <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-mono bg-blue-500/10 text-[#007acc] dark:text-[#38bdf8] border border-blue-500/20">
                <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
                Ready for Projects
              </div>
              <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight" style="line-height: 1.1;">
                Hi, I'm <span id="preview-index-name-gradient" class="bg-gradient-to-r from-blue-500 to-teal-400 bg-clip-text text-transparent">{aboutData.name}</span>
              </h1>
              <p id="preview-index-title" class="text-xl md:text-2xl font-semibold text-slate-400 dark:text-slate-300">
                {aboutData.title}
              </p>
              <p id="preview-index-desc" class="text-base md:text-lg text-slate-500 dark:text-slate-400 max-w-xl leading-relaxed">
                {aboutData.description}
              </p>
              
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-8 max-w-md">
                <div class="p-3 rounded-lg bg-black/10 dark:bg-white/5 border border-slate-700/50 flex items-center gap-3">
                  <div class="p-2 rounded bg-blue-500/10 text-blue-500">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                  </div>
                  <div>
                    <p class="text-[10px] text-slate-500 uppercase tracking-wider font-mono">Location</p>
                    <p id="preview-index-location" class="text-xs font-medium">{aboutData.location}</p>
                  </div>
                </div>
                <div class="p-3 rounded-lg bg-black/10 dark:bg-white/5 border border-slate-700/50 flex items-center gap-3">
                  <div class="p-2 rounded bg-teal-500/10 text-teal-500">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 10v6M2 10v6M22 6c0-1.1-2-2-5-2H7C4 4 2 4.9 2 6M22 18c0 1.1-2 2-5 2H7c-3 0-5-.9-5-2M2 10c0 1.1 2 2 5 2h10c3 0 5-.9 5-2"></path></svg>
                  </div>
                  <div>
                    <p class="text-[10px] text-slate-500 uppercase tracking-wider font-mono">Education</p>
                    <p id="preview-index-education" class="text-xs font-medium truncate max-w-[180px]" title={aboutData.education}>{aboutData.education}</p>
                  </div>
                </div>
              </div>

              <div class="flex flex-wrap gap-4 pt-4">
                <a id="preview-index-cv" href={aboutData.cv} target="_blank" class="px-5 py-2.5 rounded font-medium text-sm flex items-center gap-2 bg-[#007acc] text-white hover:bg-[#0062a3] transition-colors shadow-lg shadow-blue-500/25">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"></path></svg>
                  Download CV
                </a>
                <button onclick="document.querySelector('[data-section=\'contact\']').click()" class="px-5 py-2.5 rounded font-medium text-sm flex items-center gap-2 border border-slate-600 hover:bg-slate-700/20 transition-colors">
                  Contact Me
                </button>
              </div>
            </div>
          </div>
        </div>
        
      </div>
    </section>

    <!-- About Section -->
    <section id="section-about" class={`flex-1 h-full min-h-0 ${activeSection !== 'about' ? 'hidden' : ''}`}>
      <div class="panel-container">
        
        <!-- Code Panel -->
        <div class="code-panel overflow-y-auto p-6 flex-1 min-w-0" style="background: #1e1e1e;">
          <div class="font-mono text-xs md:text-sm leading-relaxed" style="color: #d4d4d4;">
            <p class="comment">---</p>
            <p><span class="key">layout</span>: <span class="string">post</span></p>
            <p><span class="key">title</span>: <span class="string">"About Me"</span></p>
            <p><span class="key">author</span>: <span class="string">"{aboutData.name}"</span></p>
            <p class="comment">---</p>
            <br/>
            <p class="text-xl font-bold" style="color: #569cd6;"># About Me</p>
            <p class="mt-2" id="code-about-bio">{aboutData.bio}</p>
          </div>
        </div>

        <!-- Preview Panel -->
        <div class="preview-panel overflow-y-auto p-6 md:p-10 flex-1 min-w-0">
          <div class="max-w-2xl mx-auto space-y-8">
            <div>
              <h2 class="text-2xl font-bold mb-1 border-none pb-0 text-slate-200">About Me</h2>
              <div class="w-12 h-1 bg-[#007acc] rounded"></div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
              <div class="md:col-span-1 flex flex-col items-center text-center p-5 rounded-lg bg-black/10 dark:bg-white/5 border border-slate-700/30">
                <!-- Glowing Avatar Placeholder -->
                <div class="w-24 h-24 rounded-full bg-gradient-to-tr from-blue-500 to-teal-400 p-[3px] shadow-lg shadow-blue-500/20 mb-4 overflow-hidden relative">
                  <div id="preview-about-avatar-fallback" class="w-full h-full rounded-full bg-slate-800 flex items-center justify-center text-2xl font-bold font-mono text-white">
                    {aboutData.name.split(' ').map(w => w[0]).join('').slice(0, 3)}
                  </div>
                  <img 
                    id="preview-about-avatar"
                    src={aboutData.avatar} 
                    alt="Avatar" 
                    class="absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-300 rounded-full" 
                    onload="this.classList.remove('opacity-0')" 
                    onerror="this.style.display='none'" 
                  />
                </div>
                <h3 id="preview-about-name" class="font-bold text-sm text-slate-200">{aboutData.name}</h3>
                <p id="preview-about-title" class="text-xs text-slate-400 mt-1">{aboutData.title}</p>
                <div class="w-full border-t border-slate-700/50 my-4"></div>
                <div class="space-y-2 w-full text-left text-xs font-mono text-slate-400">
                  <p id="preview-about-email" class="truncate">📧 {aboutData.email}</p>
                  <p id="preview-about-location-detail">📍 {aboutData.location}</p>
                </div>
              </div>

              <div id="preview-about-bio-container" class="md:col-span-2 space-y-4 text-sm leading-relaxed text-slate-300">
                {aboutData.bio.split('\n\n').map((paragraph) => (
                  <p>{paragraph}</p>
                ))}
              </div>
            </div>

            <!-- Education Timeline -->
            <div class="space-y-4">
              <h3 class="text-lg font-semibold text-slate-200">Education Timeline</h3>
              <div id="preview-about-timeline" class="relative pl-6 border-l-2 border-slate-700/80 ml-3 space-y-6">
                {aboutData.education_timeline.map((item) => (
                  <div class="relative">
                    <div class="absolute -left-[31px] top-1.5 w-4 h-4 rounded-full bg-[#007acc] border-4 border-slate-900 shadow"></div>
                    <span class="text-[10px] font-mono font-semibold px-2 py-0.5 rounded bg-blue-500/10 text-blue-400 border border-blue-500/20">{item.period}</span>
                    <h4 class="font-bold text-slate-200 mt-2 text-sm">{item.institution}</h4>
                    <p class="text-xs text-slate-400 font-mono mt-0.5">{item.major}</p>
                    <p class="text-xs text-slate-500 mt-1 leading-relaxed">{item.description}</p>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
        
      </div>
    </section>

    <!-- Skills Section -->
    <section id="section-skills" class={`flex-1 h-full min-h-0 ${activeSection !== 'skills' ? 'hidden' : ''}`}>
      <div class="panel-container">
        
        <!-- Code Panel -->
        <div class="code-panel overflow-y-auto p-6 flex-1 min-w-0" style="background: #1e1e1e;">
          <pre id="code-skills-json" class="font-mono text-xs md:text-sm leading-relaxed" style="color: #d4d4d4;">
            <p class="comment">/**</p>
            <p class="comment"> * Skills & Technologies</p>
            <p class="comment"> */</p>
            <p class="bracket">&#123;</p>
            {Object.entries(skillsData).map(([category, skills], index) => (
              <div class="pl-4">
                <p><span class="key">"{category}"</span>: <span class="bracket">[</span></p>
                {skills.map((skill, skillIndex) => (
                  <div class="pl-4">
                    <p>
                      <span class="bracket">&#123;</span>
                      <span class="key">"name"</span>: <span class="string">"{skill.name}"</span>,
                      <span class="key">"color"</span>: <span class="string">"{skill.color}"</span>
                      <span class="bracket">&#125;</span>{skillIndex < skills.length - 1 ? ',' : ''}
                    </p>
                  </div>
                ))}
                <p><span class="bracket">]</span>{index < Object.keys(skillsData).length - 1 ? ',' : ''}</p>
              </div>
            ))}
            <p class="bracket">&#125;</p>
          </pre>
        </div>

        <!-- Preview Panel -->
        <div class="preview-panel overflow-y-auto p-6 md:p-10 flex-1 min-w-0">
          <div class="max-w-2xl mx-auto space-y-8">
            <div>
              <h2 class="text-2xl font-bold mb-1 border-none pb-0 text-slate-200">Skills Dashboard</h2>
              <div class="w-12 h-1 bg-[#007acc] rounded"></div>
            </div>

            <div id="preview-skills-grid" class="grid grid-cols-1 md:grid-cols-2 gap-6">
              {Object.entries(skillsData).map(([category, skills]) => (
                <div class="preview-card p-6 rounded-xl space-y-4">
                  <h3 class="font-semibold text-sm uppercase tracking-wider text-slate-400 flex items-center gap-2">
                    <span class="w-2 h-2 rounded-full" style={`background: ${skills[0]?.color || '#007acc'};`}></span>
                    {category}
                  </h3>
                  <div class="flex flex-wrap gap-2.5 pt-1">
                    {skills.map((skill) => (
                      <div 
                        class="flex items-center gap-2 px-3 py-1.5 rounded-lg text-xs font-mono border transition-all duration-305 hover:scale-[1.03]"
                        style={`
                          background: ${skill.color}12; 
                          border-color: ${skill.color}25; 
                          color: var(--vscode-text);
                        `}
                        onmouseover={`this.style.background='${skill.color}22'; this.style.borderColor='${skill.color}60'; this.style.boxShadow='0 4px 12px -2px ${skill.color}30'`}
                        onmouseout={`this.style.background='${skill.color}12'; this.style.borderColor='${skill.color}25'; this.style.boxShadow='none'`}
                      >
                        <span class="w-2.5 h-2.5 rounded-full flex-shrink-0" style={`background: ${skill.color}; box-shadow: 0 0 8px ${skill.color};`}></span>
                        <span>{skill.name}</span>
                      </div>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
        
      </div>
    </section>

    <!-- Projects Section -->
    <section id="section-projects" class={`flex-1 h-full min-h-0 ${activeSection !== 'projects' ? 'hidden' : ''}`}>
      <div class="panel-container">
        
        <!-- Code Panel -->
        <div class="code-panel overflow-y-auto p-6 flex-1 min-w-0" style="background: #1e1e1e;">
          <pre id="code-projects-json" class="font-mono text-xs md:text-sm leading-relaxed" style="color: #d4d4d4;">
            <p class="comment">/**</p>
            <p class="comment"> * Projects Portfolio</p>
            <p class="comment"> */</p>
            <p class="bracket">[</p>
            {projectsData.map((project, index) => (
              <div class="pl-4">
                <p><span class="bracket">&#123;</span></p>
                <div class="pl-4">
                  <p><span class="key">"id"</span>: <span style="color: #b5cea8;">{project.id}</span>,</p>
                  <p><span class="key">"title"</span>: <span class="string">"{project.title}"</span>,</p>
                  <p><span class="key">"tech"</span>: <span class="bracket">[</span>{project.tech.map((t, i) => (
                    <span><span class="string">"{t}"</span>{i < project.tech.length - 1 ? ', ' : ''}</span>
                  ))}<span class="bracket">]</span>,</p>
                  <p><span class="key">"status"</span>: <span style="color: #4ec9b0;">"{project.status}"</span></p>
                </div>
                <p><span class="bracket">&#125;</span>{index < projectsData.length - 1 ? ',' : ''}</p>
              </div>
            ))}
            <p class="bracket">]</p>
          </pre>
        </div>

        <!-- Preview Panel -->
        <div class="preview-panel overflow-y-auto p-6 md:p-10 flex-1 min-w-0">
          <div class="max-w-3xl mx-auto space-y-8">
            <div>
              <h2 class="text-2xl font-bold mb-1 border-none pb-0 text-slate-200">Projects Portfolio</h2>
              <div class="w-12 h-1 bg-[#007acc] rounded"></div>
            </div>

            <div id="preview-projects-grid" class="grid grid-cols-1 md:grid-cols-2 gap-6">
              {projectsData.map((project) => (
                <div class="preview-card p-5 rounded-xl flex flex-col justify-between space-y-4">
                  <!-- Project Cover (Image or Gradient Fallback) -->
                  <div class="h-32 rounded-lg overflow-hidden relative bg-gradient-to-br from-slate-800 to-slate-900 border border-slate-700/50 flex items-center justify-center group">
                    <span class="text-3xl font-bold font-mono tracking-wider text-slate-700/60 select-none uppercase">
                      {project.title.split(' ').map(w => w[0]).join('').slice(0, 3)}
                    </span>
                    <img 
                      src={project.image} 
                      alt={project.title} 
                      class="absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-300 rounded-lg" 
                      onload="this.classList.remove('opacity-0')" 
                      onerror="this.style.display='none'" 
                    />
                  </div>

                  <div class="space-y-2">
                    <div class="flex justify-between items-start">
                      <h3 class="font-bold text-base text-slate-200 leading-snug">{project.title}</h3>
                      <span class={`text-[9px] font-mono px-2 py-0.5 rounded-full border flex-shrink-0 ${
                        project.status === 'completed' 
                          ? 'bg-green-500/10 text-green-400 border-green-500/25' 
                          : 'bg-yellow-500/10 text-yellow-400 border-yellow-500/25'
                      }`}>
                        {project.status === 'completed' ? '✓ Completed' : '⚙ In Progress'}
                      </span>
                    </div>
                    
                    <p class="text-xs text-slate-400 leading-relaxed">{project.description}</p>
                  </div>

                  <div class="space-y-3.5 pt-2">
                    <!-- Tech tags -->
                    <div class="flex flex-wrap gap-1.5">
                      {project.tech.map((tech) => (
                        <span class="text-[9px] font-mono px-2 py-0.5 rounded bg-slate-800/80 text-[#007acc] dark:text-[#38bdf8] border border-slate-700/60">
                          {tech}
                        </span>
                      ))}
                    </div>

                    <!-- Action Links -->
                    <div class="flex items-center gap-3 pt-1 border-t border-slate-800/60">
                      {project.github !== '#' && (
                        <a href={project.github} target="_blank" rel="noopener" class="text-xs font-semibold text-slate-400 hover:text-white flex items-center gap-1 transition-colors">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
                          GitHub
                        </a>
                      )}
                      {project.demo !== '#' && (
                        <a href={project.demo} target="_blank" rel="noopener" class="text-xs font-semibold text-[#007acc] dark:text-[#38bdf8] hover:underline flex items-center gap-1 transition-colors">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14L21 3"></path></svg>
                          Live Demo
                        </a>
                      )}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
        
      </div>
    </section>

    <!-- Contact Section -->
    <section id="section-contact" class={`flex-1 h-full min-h-0 ${activeSection !== 'contact' ? 'hidden' : ''}`}>
      <div class="panel-container">
        
        <!-- Code Panel -->
        <div class="code-panel overflow-y-auto p-6 flex-1 min-w-0" style="background: #1e1e1e;">
          <pre id="code-contact-json" class="font-mono text-xs md:text-sm leading-relaxed" style="color: #d4d4d4;">
            <p class="comment">// Contact Information</p>
            <p class="bracket">&#123;</p>
            <div class="pl-4">
              <p><span class="key">"name"</span>: <span class="string">"{aboutData.name}"</span>,</p>
              <p><span class="key">"title"</span>: <span class="string">"{aboutData.title}"</span>,</p>
              <p><span class="key">"email"</span>: <span class="string">"{aboutData.email}"</span>,</p>
              <p><span class="key">"github"</span>: <span class="string">"{aboutData.github}"</span>,</p>
              <p><span class="key">"location"</span>: <span class="string">"{aboutData.location}"</span>,</p>
              <p><span class="key">"availableForFreelance"</span>: <span style="color: #4ec9b0;">true</span></p>
            </div>
            <p class="bracket">&#125;</p>
          </pre>
        </div>

        <!-- Preview Panel -->
        <div class="preview-panel overflow-y-auto p-6 md:p-10 flex-1 min-w-0">
          <div class="max-w-xl mx-auto space-y-8">
            <div>
              <h2 class="text-2xl font-bold mb-1 border-none pb-0 text-slate-200">Get In Touch</h2>
              <div class="w-12 h-1 bg-[#007acc] rounded"></div>
            </div>

            <div class="preview-card p-6 rounded-xl space-y-6">
              <div class="flex items-center gap-3">
                <span class="w-3 h-3 rounded-full bg-green-500 animate-pulse flex-shrink-0"></span>
                <span class="text-xs font-mono font-medium text-green-400">Available for freelance projects & full-time roles</span>
              </div>

              <!-- Simulated Form -->
              <div class="space-y-4">
                <div class="grid grid-cols-2 gap-4">
                  <div class="space-y-1.5">
                    <label class="text-[11px] font-mono text-slate-400">YOUR NAME</label>
                    <input type="text" placeholder="John Doe" class="w-full bg-slate-900/50 border border-slate-700/50 rounded px-3 py-2 text-xs focus:outline-none focus:border-[#007acc] text-slate-200" />
                  </div>
                  <div class="space-y-1.5">
                    <label class="text-[11px] font-mono text-slate-400">EMAIL ADDRESS</label>
                    <input type="email" placeholder="john@example.com" class="w-full bg-slate-900/50 border border-slate-700/50 rounded px-3 py-2 text-xs focus:outline-none focus:border-[#007acc] text-slate-200" />
                  </div>
                </div>
                <div class="space-y-1.5">
                  <label class="text-[11px] font-mono text-slate-400">MESSAGE</label>
                  <textarea rows="4" placeholder="Hello! I would love to talk about a project..." class="w-full bg-slate-900/50 border border-slate-700/50 rounded px-3 py-2 text-xs focus:outline-none focus:border-[#007acc] text-slate-200 resize-none"></textarea>
                </div>
                
                <button type="button" class="w-full py-2.5 rounded font-medium text-xs bg-[#007acc] text-white hover:bg-[#0062a3] transition-colors shadow-lg shadow-blue-500/10">
                  Send Message
