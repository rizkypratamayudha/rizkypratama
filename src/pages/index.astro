        }

        if (updatedCount > 0) {
          logOutput(`[GitHub Sync] Sinkronisasi selesai! Berhasil menyinkronkan data portofolio.`);
        } else {
          logOutput(`[GitHub Sync] Selesai. Tidak ditemukan issue berlabel 'about', 'skill', atau 'project'.`);
        }
      } catch (err) {
        logOutput(`[GitHub Sync] Gagal sinkronisasi: ${(err as any).message}. Fallback ke lokal.`);
      }
    }

    setTimeout(syncGitHubIssues, 1500);

    // Navigation & Continuous Scroll Logic
    const sidebarButtons = document.querySelectorAll('.file-item[data-section]');
    const tabButtons = document.querySelectorAll('.tab-item[data-tab]');
    const codeBlocks = document.querySelectorAll('.code-block');
    const sections = document.querySelectorAll('section[data-section-name]');
    const previewPanel = document.getElementById('main-preview-panel');
    const breadcrumb = document.getElementById('breadcrumb-file');

    const fileMap: Record<string, string> = {
      index: 'index.html',
      about: 'about.md',
      skills: 'skills.json',
      projects: 'projects.json',
      contact: 'contact.json',
    };

    let isProgrammaticScroll = false;
    let currentActiveSection = '';

    function setActiveSectionUI(sectionId: string) {
      if (currentActiveSection === sectionId) return;
      currentActiveSection = sectionId;

      // Update sidebar
      sidebarButtons.forEach((btn) => {
        const btnSection = (btn as HTMLElement).dataset.section;
        if (btnSection === sectionId) {
          btn.classList.add('active');
        } else {
          btn.classList.remove('active');
        }
      });

      // Update tabs
      tabButtons.forEach((tab) => {
        const tabSection = (tab as HTMLElement).dataset.tab;
        if (tabSection === sectionId) {
          tab.classList.add('active');
          (tab as HTMLElement).style.borderTopColor = '#007acc';
        } else {
          tab.classList.remove('active');
          (tab as HTMLElement).style.borderTopColor = 'transparent';
        }
      });

      // Update code blocks in Code Panel
      codeBlocks.forEach((block) => {
        if (block.id === `code-block-${sectionId}`) {
          block.classList.remove('hidden');
        } else {
          block.classList.add('hidden');
        }
      });

      // Update breadcrumb
      if (breadcrumb) {
        breadcrumb.textContent = fileMap[sectionId] || 'index.html';
      }
    }

    function navigateToSection(sectionId: string) {
      setActiveSectionUI(sectionId);

      const targetSection = document.getElementById(`section-${sectionId}`);
      if (targetSection && previewPanel) {
        isProgrammaticScroll = true;
        targetSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
        setTimeout(() => {
          isProgrammaticScroll = false;
        }, 800);
      }
    }

    // Initialize first section UI
    setActiveSectionUI('index');

    // IntersectionObserver for Continuous Scroll
    if (previewPanel && sections.length > 0) {
      const observerOptions = {
        root: previewPanel,
        rootMargin: '-20% 0px -55% 0px',
        threshold: 0
      };

      const observer = new IntersectionObserver((entries) => {
        if (isProgrammaticScroll) return;
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const sectionName = (entry.target as HTMLElement).dataset.sectionName;
            if (sectionName) {
              setActiveSectionUI(sectionName);
            }
          }
        });
      }, observerOptions);

      sections.forEach((section) => observer.observe(section));
    }

    // Sidebar click handlers
    sidebarButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const sectionId = (btn as HTMLElement).dataset.section;
        if (sectionId) {
          navigateToSection(sectionId);
        }
      });
    });

    // Tab click handlers
    tabButtons.forEach((tab) => {
      tab.addEventListener('click', () => {
        const sectionId = (tab as HTMLElement).dataset.tab;
        if (sectionId) {
          navigateToSection(sectionId);
        }
      });
    });

    // Activity bar buttons
    const explorerBtn = document.getElementById('btn-explorer');
    const sidebar = document.querySelector('.sidebar');

    explorerBtn?.addEventListener('click', () => {
      if (sidebar) {
        const sidebarElement = sidebar as HTMLElement;
        if (sidebarElement.classList.contains('w-0')) {
          sidebarElement.classList.remove('w-0');
          sidebarElement.classList.add('lg:w-64');
        } else {
          sidebarElement.classList.add('w-0');
          sidebarElement.classList.remove('lg:w-64');
        }
      }
    });

    // ── Project Detail Modal Functions ─────────────────────────────────────────
    function openProjectModal(projectId: number | string) {
      const proj = allFetchedProjects.find(p => String(p.id) === String(projectId));
      if (!proj) return;

      const modal = document.getElementById('project-detail-modal');
      const title = document.getElementById('modal-project-title');
      const status = document.getElementById('modal-project-status');
      const desc = document.getElementById('modal-project-desc');
      const tech = document.getElementById('modal-project-tech');
      const github = document.getElementById('modal-project-github') as HTMLAnchorElement;
      const demo = document.getElementById('modal-project-demo') as HTMLAnchorElement;

      if (title) title.textContent = proj.title;
      if (status) {
        status.innerHTML = `
          <span class="text-[11px] font-mono px-2.5 py-0.5 rounded-full border ${
            proj.status === 'completed' 
              ? 'bg-teal-500/10 text-teal-400 border-teal-500/25' 
              : 'bg-amber-500/10 text-amber-400 border-amber-500/25'
          }">
            ${proj.status === 'completed' ? '✓ Completed' : '⚙ In Progress'}
          </span>
        `;
      }
      if (desc) desc.textContent = proj.description || 'Tidak ada deskripsi rinci.';
      if (tech) {
        tech.innerHTML = proj.tech.map((t: string) => `
          <span class="skill-tag tag-blue text-xs font-mono">${t}</span>
        `).join('');
      }

      if (github) {
        if (proj.github && proj.github !== '#') {
          github.setAttribute('href', proj.github);
          github.style.display = 'inline-flex';
        } else {
          github.style.display = 'none';
        }
      }

      if (demo) {
        if (proj.demo && proj.demo !== '#') {
          demo.setAttribute('href', proj.demo);
          demo.style.display = 'inline-flex';
        } else {
          demo.style.display = 'none';
        }
      }

      // Setup Carousel
      currentModalImages = proj.images && proj.images.length > 0 ? proj.images : [proj.image || '#'];
      currentImageIndex = 0;
      updateCarouselView();

      if (modal) {
        modal.classList.remove('hidden');
        void modal.offsetHeight;
        modal.classList.remove('opacity-0', 'pointer-events-none');
        modal.classList.add('opacity-100', 'pointer-events-auto');
      }
    }

    function closeProjectModal() {
      const modal = document.getElementById('project-detail-modal');
      if (modal) {
        modal.classList.remove('opacity-100', 'pointer-events-auto');
        modal.classList.add('opacity-0', 'pointer-events-none');
        setTimeout(() => {
          modal.classList.add('hidden');
        }, 300);
      }
    }

    function updateCarouselView() {
      const imgEl = document.getElementById('modal-carousel-img') as HTMLImageElement;
      const prevBtn = document.getElementById('modal-carousel-prev');
      const nextBtn = document.getElementById('modal-carousel-next');
      const counter = document.getElementById('modal-carousel-counter');
      const thumbsContainer = document.getElementById('modal-carousel-thumbnails');

      const total = currentModalImages.length;
      const validUrl = currentModalImages[currentImageIndex] !== '#' ? currentModalImages[currentImageIndex] : '';

      if (imgEl) {
        if (validUrl) {
          imgEl.src = validUrl;
          imgEl.style.display = 'block';
        } else {
          imgEl.style.display = 'none';
        }
      }

      if (total > 1) {
        if (prevBtn) prevBtn.classList.remove('hidden');
        if (nextBtn) nextBtn.classList.remove('hidden');
        if (counter) {
          counter.classList.remove('hidden');
          counter.textContent = `${currentImageIndex + 1} / ${total}`;
        }
        if (thumbsContainer) {
          thumbsContainer.classList.remove('hidden');
          thumbsContainer.innerHTML = currentModalImages.map((imgUrl, i) => `
            <button class="w-16 h-12 rounded-lg overflow-hidden border-2 flex-shrink-0 transition-all ${
              i === currentImageIndex ? 'border-indigo-500 scale-105 shadow-md shadow-indigo-500/30' : 'border-slate-800 opacity-60 hover:opacity-100'
            }" data-thumb-index="${i}">
              <img src="${imgUrl}" alt="Thumbnail ${i+1}" class="w-full h-full object-cover" />
            </button>
          `).join('');

          thumbsContainer.querySelectorAll('[data-thumb-index]').forEach(btn => {
            btn.addEventListener('click', (e) => {
              const idx = parseInt((e.currentTarget as HTMLElement).dataset.thumbIndex || '0', 10);
              currentImageIndex = idx;
              updateCarouselView();
            });
          });
        }
      } else {
        if (prevBtn) prevBtn.classList.add('hidden');
        if (nextBtn) nextBtn.classList.add('hidden');
        if (counter) counter.classList.add('hidden');
        if (thumbsContainer) thumbsContainer.classList.add('hidden');
      }
    }

    // Modal Control Event Listeners
    const btnCloseModal = document.getElementById('btn-close-project-modal');
    const modalEl = document.getElementById('project-detail-modal');
    const prevBtn = document.getElementById('modal-carousel-prev');
    const nextBtn = document.getElementById('modal-carousel-next');

    btnCloseModal?.addEventListener('click', closeProjectModal);

    modalEl?.addEventListener('click', (e) => {
      if (e.target === modalEl) {
        closeProjectModal();
      }
    });

    prevBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      if (currentModalImages.length > 0) {
        currentImageIndex = (currentImageIndex - 1 + currentModalImages.length) % currentModalImages.length;
        updateCarouselView();
      }
    });

    nextBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      if (currentModalImages.length > 0) {
        currentImageIndex = (currentImageIndex + 1) % currentModalImages.length;
        updateCarouselView();
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        closeProjectModal();
      }
    });

    // Mobile: close sidebar when clicking on a section
    if (window.innerWidth < 1024) {
      sidebarButtons.forEach((btn) => {
        btn.addEventListener('click', () => {
          if (sidebar) {
            const sidebarElement = sidebar as HTMLElement;
            sidebarElement.classList.add('w-0');
            sidebarElement.classList.remove('lg:w-64');
          }
        });
      });
    }
  });
</script>

