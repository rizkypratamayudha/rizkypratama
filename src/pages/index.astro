                <div class="h-36 rounded-lg overflow-hidden relative bg-gradient-to-br from-slate-800 to-slate-900 border border-slate-700/30 flex items-center justify-center">
                  <span class="text-3xl font-bold font-mono tracking-wider text-slate-700/40 select-none uppercase">
                    ${project.title.split(' ').map((w: string) => w[0]).join('').slice(0, 3)}
