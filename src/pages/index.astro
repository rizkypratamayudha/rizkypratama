<span class="comment">/**</span>
<span class="comment"> * Skills & Technologies (Synced from GitHub Issues)</span>
<span class="comment"> */</span>
<span class="bracket">&#123;</span>
${Object.entries(skills).map(([category, list], index) => {
  return `  <span class="key">"${category}"</span>: <span class="bracket">[</span>
${list.map((skill, skillIndex) => `    <span class="bracket">&#123;</span> <span class="key">"name"</span>: <span class="string">"${skill.name}"</span>, <span class="key">"color"</span>: <span class="string">"${skill.color}"</span>${skill.icon ? `, <span class="key">"icon"</span>: <span class="string">"${skill.icon}"</span>` : ''} <span class="bracket">&#125;</span>${skillIndex < list.length - 1 ? ',' : ''}`).join('\n')}
  <span class="bracket">]</span>${index < Object.keys(skills).length - 1 ? ',' : ''}`;
