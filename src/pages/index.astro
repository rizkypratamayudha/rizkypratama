                  ${project.images && project.images.length > 1 ? `
                    <span class="absolute top-2.5 right-2.5 px-2.5 py-1 rounded-full bg-black/75 text-white text-[10px] font-mono flex items-center gap-1 backdrop-blur-md border border-white/10 shadow-lg">
                      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
                      ${project.images.length} Photos
                    </span>
                  ` : ''}
                </div>

                <div class="space-y-2">
                  <div class="flex justify-between items-start">
                    <h3 class="font-bold text-base text-slate-200 leading-snug font-display group-hover:text-indigo-400 transition-colors">${project.title}</h3>
                    <span class="text-[10px] font-mono px-2 py-0.5 rounded-full border flex-shrink-0 ${
                      project.status === 'completed' 
                        ? 'bg-teal-500/10 text-teal-400 border-teal-500/25' 
                        : 'bg-amber-500/10 text-amber-400 border-amber-500/25'
                    }">
                      ${project.status === 'completed' ? '✓ Done' : '⚙ WIP'}
                    </span>
                  </div>
                  <p class="text-xs text-slate-400/80 leading-relaxed line-clamp-2">${project.description}</p>
                </div>

                <div class="space-y-3 pt-2">
                  <div class="flex flex-wrap gap-1.5">
                    ${project.tech.map((tech: string) => `
                      <span class="skill-tag tag-blue text-[10px]">
                        ${tech}
                      </span>
                    `).join('')}
                  </div>

                  <div class="flex items-center justify-between pt-2 border-t border-white/5">
                    <div class="flex items-center gap-3">
                      ${project.github !== '#' ? `
                        <a href="${project.github}" target="_blank" rel="noopener" class="text-xs font-semibold text-slate-400 hover:text-white flex items-center gap-1.5 transition-colors project-external-link">
                          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
                          Source
                        </a>
                      ` : ''}
                      ${project.demo !== '#' ? `
                        <a href="${project.demo}" target="_blank" rel="noopener" class="text-xs font-semibold text-indigo-400 hover:text-indigo-300 flex items-center gap-1.5 transition-colors project-external-link">
                          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14L21 3"></path></svg>
                          Live Demo
                        </a>
                      ` : ''}
                    </div>
                    <span class="text-[10px] font-mono text-indigo-400 group-hover:translate-x-1 transition-transform flex items-center gap-1">
                      Details &rarr;
                    </span>
                  </div>
                </div>
              </div>
            `).join('');

            projectsGrid.querySelectorAll('[data-project-id]').forEach(card => {
              card.addEventListener('click', (e) => {
                const target = e.target as HTMLElement;
                if (target.closest('.project-external-link')) return;
                const projId = (card as HTMLElement).dataset.projectId;
                if (projId) openProjectModal(projId);
              });
            });
          }

          const codeProjectsJson = document.getElementById('code-projects-json');
          if (codeProjectsJson) {
            codeProjectsJson.innerHTML = `
<span class="comment">/**</span>
<span class="comment"> * Projects Portfolio (Synced from GitHub Issues)</span>
<span class="comment"> */</span>
<span class="bracket">[</span>
${projects.map((project, index) => `  <span class="bracket">&#123;</span>
    <span class="key">"id"</span>: <span style="color: #b5cea8;">${project.id}</span>,
    <span class="key">"title"</span>: <span class="string">"${project.title}"</span>,
    <span class="key">"tech"</span>: <span class="bracket">[</span>${project.tech.map((t: string) => `<span class="string">"${t}"</span>`).join(', ')}<span class="bracket">]</span>,
    <span class="key">"status"</span>: <span style="color: #4ec9b0;">"${project.status}"</span>
  <span class="bracket">&#125;</span>${index < projects.length - 1 ? ',' : ''}`).join('\n')}
<span class="bracket">]</span>
            `;
          }

          const sidebarProjects = document.getElementById('projects-children');
          if (sidebarProjects) {
            sidebarProjects.innerHTML = projects.map(project => `
              <button class="file-item" style="padding-left: 32px;" data-project="${project.id}">
                <span class="w-2 h-2 rounded-full flex-shrink-0 bg-green-400"></span>
                <span class="truncate flex-1">project${project.id}.json</span>
              </button>
            `).join('');

            sidebarProjects.querySelectorAll('[data-project]').forEach(btn => {
              btn.addEventListener('click', () => {
                const projId = (btn as HTMLElement).dataset.project;
                if (projId) openProjectModal(projId);
              });
            });
